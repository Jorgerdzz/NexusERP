@{
    ViewData["Title"] = "Mi Panel";
}

<div class="container-fluid py-4 min-vh-100" style="background-color: #f8fafc; animation: fadeIn 0.5s ease-out forwards;">
    
    <!-- Welcome Header -->
    <div class="mb-5 d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-3">
        <div>
            <h2 class="fw-bold text-dark-heading mb-2 d-flex align-items-center gap-2" style="letter-spacing: -0.5px;">
                <span style="font-size: 2.2rem; transform: origin;">👋</span> ¡Hola, @ViewBag.NombreEmpleado!
            </h2>
            <p class="text-muted mb-0 fs-5">Bienvenido a tu espacio personal de empleado.</p>
        </div>
        <div class="d-none d-md-flex align-items-center px-4 py-2 bg-white rounded-pill shadow-sm border border-light">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-primary me-2">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <span class="text-dark fw-medium small mb-0" style="text-transform: capitalize;">@DateTime.Now.ToString("dddd, dd MMMM", new System.Globalization.CultureInfo("es-ES"))</span>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-4 mb-5">
        
        <!-- Nóminas -->
        <div class="col-md-6 col-lg-4">
            <div class="card bg-white border-0 shadow-sm rounded-4 h-100 transition-hover" style="overflow: hidden;">
                <div style="height: 4px; background: linear-gradient(90deg, #0ea5e9, #38bdf8);"></div>
                <div class="card-body p-4 p-xl-5 position-relative">
                    <div class="position-absolute top-0 end-0 p-4 opacity-25">
                         <svg width="80" height="80" fill="none" stroke="#0ea5e9" viewBox="0 0 24 24" stroke-width="1">
                             <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                         </svg>
                    </div>
                    
                    <div class="d-flex align-items-center mb-4 position-relative z-1">
                        <div class="d-flex align-items-center justify-content-center rounded-circle shadow-sm" style="width: 56px; height: 56px; background: linear-gradient(135deg, #e0f2fe, #bae6fd); color: #0284c7;">
                            <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                    </div>
                    <h5 class="fw-bold text-dark-heading mb-2 position-relative z-1 fs-4">Mis Nóminas</h5>
                    <p class="text-muted mb-4 position-relative z-1" style="font-size: 0.95rem;">Consulta, revisa y descarga tus recibos salariales mensuales en formato oficial.</p>
                    
                    <a asp-action="MisNominas" class="btn btn-primary bg-primary bg-gradient border-0 text-white d-inline-flex align-items-center gap-2 rounded-pill px-4 py-2 fw-semibold shadow-sm mt-auto w-100 justify-content-center btn-hover-grow">
                        Acceder a mis nóminas
                        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        <!-- Perfil -->
        <div class="col-md-6 col-lg-4">
            <div class="card bg-white border-0 shadow-sm rounded-4 h-100 transition-hover" style="overflow: hidden;">
                <div style="height: 4px; background: linear-gradient(90deg, #8b5cf6, #c084fc);"></div>
                <div class="card-body p-4 p-xl-5 position-relative">
                    <div class="position-absolute top-0 end-0 p-4 opacity-25">
                         <svg width="80" height="80" fill="none" stroke="#8b5cf6" viewBox="0 0 24 24" stroke-width="1">
                             <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                         </svg>
                    </div>
                    
                    <div class="d-flex align-items-center mb-4 position-relative z-1">
                        <div class="d-flex align-items-center justify-content-center rounded-circle shadow-sm" style="width: 56px; height: 56px; background: linear-gradient(135deg, #f3e8ff, #e9d5ff); color: #7e22ce;">
                            <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                        </div>
                    </div>
                    <h5 class="fw-bold text-dark-heading mb-2 position-relative z-1 fs-4">Mi Perfil</h5>
                    <p class="text-muted mb-4 position-relative z-1" style="font-size: 0.95rem;">Visualiza y mantén actualizada tu información fiscal y contacto corporativo.</p>
                    
                    <a asp-controller="Profile" asp-action="Index" class="btn border border-secondary text-dark bg-white d-inline-flex align-items-center gap-2 rounded-pill px-4 py-2 fw-semibold shadow-sm mt-auto w-100 justify-content-center custom-hover-btn">
                        Ver mis datos
                        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        <!-- Vacaciones (Próximamente) -->
        <div class="col-md-6 col-lg-4">
            <div class="card bg-white border-0 shadow-sm rounded-4 h-100 transition-hover" style="overflow: hidden; opacity: 0.85;">
                <div style="height: 4px; background: linear-gradient(90deg, #10b981, #34d399);"></div>
                <div class="card-body p-4 p-xl-5 position-relative">
                    <div class="position-absolute top-0 end-0 p-4 opacity-25">
                         <svg width="80" height="80" fill="none" stroke="#10b981" viewBox="0 0 24 24" stroke-width="1">
                             <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                         </svg>
                    </div>

                    <div class="d-flex align-items-center mb-4 position-relative z-1">
                        <div class="d-flex align-items-center justify-content-center rounded-circle shadow-sm" style="width: 56px; height: 56px; background: linear-gradient(135deg, #d1fae5, #a7f3d0); color: #047857;">
                            <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                    </div>
                    <h5 class="fw-bold text-dark-heading mb-2 position-relative z-1 fs-4">Ausencias</h5>
                    <p class="text-muted mb-4 position-relative z-1" style="font-size: 0.95rem;">Gestiona tus días libres, solicita vacaciones y revisa el estado de tus peticiones.</p>
                    
                    <button class="btn border border-light text-muted bg-light d-inline-flex align-items-center gap-2 rounded-pill px-4 py-2 fw-semibold w-100 justify-content-center" disabled style="cursor: not-allowed;">
                        Próximamente
                    </button>
                    <!-- Insignia Coming Soon -->
                    <div class="position-absolute top-0 end-0 mt-4 me-4">
                         <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-1">En desarrollo</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Additional Information Section -->
    <div class="row g-4">
        <!-- Announcements / Tablón -->
        <div class="col-lg-8">
            <div class="card bg-white border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4 d-flex align-items-center gap-3">
                    <div class="p-2 bg-light text-secondary rounded-3 border">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path>
                        </svg>
                    </div>
                    <h5 class="fw-bold mb-0 text-dark-heading">Tablón de Anuncios Corporativo</h5>
                </div>
                <div class="card-body p-4 pt-3">
                    <div class="d-flex flex-column gap-3">
                        
                        <div class="d-flex gap-3 p-4 rounded-4 bg-light border border-light position-relative overflow-hidden group-hover-bg">
                            <div class="position-absolute top-0 start-0 w-100 h-100 bg-white opacity-50" style="z-index: 0; pointer-events: none;"></div>
                            
                            <div class="p-3 bg-white rounded-3 shadow-sm d-flex align-items-center justify-content-center z-1" style="width: 54px; height: 54px;">
                                <span class="fs-4">🚀</span>
                            </div>
                            
                            <div class="flex-grow-1 z-1">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h6 class="fw-bold mb-0 text-dark">Lanzamiento del nuevo Portal</h6>
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-2 py-1" style="font-size: 0.70rem;">Nuevo</span>
                                </div>
                                <p class="text-muted small mb-0">Hemos actualizado nuestra plataforma ERP. Ahora es más rápida, accesible y puedes descargar tus nóminas con pleno valor legal en un par de clics.</p>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <!-- Help & Contact -->
        <div class="col-lg-4">
            <div class="card bg-white border-0 shadow-sm rounded-4 h-100 p-4 text-center d-flex flex-column justify-content-center align-items-center position-relative overflow-hidden">
                <!-- Decoración -->
                <div class="position-absolute top-0 start-50 translate-middle-x bg-primary rounded-bottom" style="width: 60px; height: 6px;"></div>
                
                <div class="mb-4 mt-3 rounded-circle d-flex align-items-center justify-content-center shadow-sm border border-3 border-white" style="width: 80px; height: 80px; background: linear-gradient(135deg, #f8fafc, #f1f5f9);">
                    <svg width="40" height="40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" style="color: #64748b;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                </div>
                <h5 class="fw-bold text-dark-heading mb-2">¿Necesitas ayuda?</h5>
                <p class="text-muted small mb-4 px-3">Si tienes algún inconveniente con tus recibos, datos personales o necesitas asistencia, nuestro equipo está a tu disposición.</p>
                <a href="mailto:rrhh@empresa.com" class="btn border btn-outline-secondary d-inline-flex align-items-center gap-2 rounded-pill px-4 py-2 fw-medium text-dark-heading custom-hover-btn mt-auto">
                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                    </svg>
                    Contactar a RRHH
                </a>
            </div>
        </div>
    </div>

</div>

<style>
    .transition-hover {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .transition-hover:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04) !important;
    }
    
    .btn-hover-grow {
        transition: transform 0.2s ease-in-out;
    }
    .btn-hover-grow:hover {
        transform: scale(1.03);
    }
    
    .custom-hover-btn {
        transition: all 0.2s;
    }
    .custom-hover-btn:hover {
        background-color: #f8fafc !important;
        border-color: #cbd5e1 !important;
        transform: translateY(-2px);
    }
    
    .text-dark-heading {
        color: #0f172a;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(15px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>