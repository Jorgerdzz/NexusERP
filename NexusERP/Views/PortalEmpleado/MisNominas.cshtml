@model NexusERP.ViewModels.MisNominasViewModel

@{
    ViewData["Title"] = "Mis Nóminas";

    if (User.IsInRole(RolesUsuario.Admin.ToString()))
    {
        Layout = "_LayoutERP";
        ViewData["ActiveMenu"] = "Payroll";
    }
    else
    {
        Layout = "_LayoutERP";
        ViewData["ActiveMenu"] = "NominasEmpleado";
    }

}

<div class="container-fluid py-4 min-vh-100" style="background-color: #f8fafc;">

    <div class="row justify-content-center mb-5">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex align-items-center mb-4">
                        <div class="d-flex align-items-center justify-content-center rounded-circle shadow-sm me-3" style="width: 48px; height: 48px; background-color: #e0f2fe; color: #0284c7;">
                            <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-1">Período de Liquidación</h5>
                            <p class="text-muted small mb-0">Selecciona el mes y año para consultar el recibo</p>
                        </div>
                    </div>

                    <form asp-action="MisNominas" method="get" class="row g-3 align-items-end">
                        @if (ViewBag.EmpleadoId != null)
                        {
                            <input type="hidden" name="empleadoId" value="@ViewBag.EmpleadoId" />
                        }
                        <div class="col-md-5">
                            <label class="form-label small fw-bold text-muted text-uppercase mb-2" style="letter-spacing: 0.5px;">Mes</label>
                            <select name="mes" class="form-select shadow-none py-2 form-select-payroll" style="border-radius: 0.5rem; border-color: #cbd5e1; background-color: #f8fafc;">
                                @for (int i = 1; i <= 12; i++)
                                {
                                    string nombreMes = new DateTime(2000, i, 1).ToString("MMMM", new System.Globalization.CultureInfo("es-ES"));
                                    nombreMes = char.ToUpper(nombreMes[0]) + nombreMes.Substring(1);

                                    // Si el mes del bucle coincide con el seleccionado, lo marcamos
                                    if (Model.MesSeleccionado == i)
                                    {
                                        <option value="@i" selected>@nombreMes</option>
                                    }
                                    else
                                    {
                                        <option value="@i">@nombreMes</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted text-uppercase mb-2" style="letter-spacing: 0.5px;">Año</label>
                            <select name="ano" class="form-select shadow-none py-2 form-select-payroll" style="border-radius: 0.5rem; border-color: #cbd5e1; background-color: #f8fafc;">
                                @for (int i = DateTime.Now.Year - 2; i <= DateTime.Now.Year + 1; i++)
                                {
                                    if (Model.AnoSeleccionado == i)
                                    {
                                        <option value="@i" selected>@i</option>
                                    }
                                    else
                                    {
                                        <option value="@i">@i</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold shadow-sm d-flex align-items-center justify-content-center gap-2" style="border-radius: 0.5rem; background-color: #0d6efd; border-color: #0d6efd; transition: all 0.2s ease;">
                                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                </svg>
                                Buscar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @if (Model.NominaActual != null)
    {
        <div class="d-flex justify-content-end mb-3" style="max-width: 900px; margin: 0 auto;">
            <a asp-controller="Payroll" asp-action="DescargarPdf" asp-route-idNomina="@Model.NominaActual.Id" class="btn btn-success d-flex align-items-center gap-2 px-4 shadow-sm" style="border-radius: 0.5rem;">
                <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Descargar PDF Oficial
            </a>
        </div>

        <div class="payslip-container">

            <!-- Header de la nómina -->
            <div class="row payslip-header">
                <div class="col-md-6 mb-3 mb-md-0">
                    <h5 class="fw-bold text-dark mb-2">@Model.NominaActual.Empresa?.NombreComercial</h5>
                    <p class="text-muted mb-1">
                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="me-1">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        CIF: <strong>@Model.NominaActual.Empresa?.Cif</strong>
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <h4 class="payslip-title mb-3">RECIBO DE SALARIOS</h4>
                    <p class="text-dark fw-semibold mb-2">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="me-1">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 01-2 2z"></path>
                        </svg>
                        Período: @Model.NominaActual.FechaInicio.ToString("dd/MM/yyyy") al @Model.NominaActual.FechaFin.ToString("dd/MM/yyyy")
                    </p>
                    @if (Model.NominaActual.Estado == "Pagada")
                    {
                        <span class="badge-status pagada">
                            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            PAGADA
                        </span>
                    }
                    else
                    {
                        <span class="badge-status pendiente">
                            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            PENDIENTE
                        </span>
                    }
                </div>
            </div>

            <!-- Información del empleado -->
            <div class="employee-info-card">
                <div class="row">
                    <div class="col-md-6 info-section-divider mb-3 mb-md-0">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-secondary-custom">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                            <span class="text-muted small fw-bold text-uppercase">Trabajador</span>
                        </div>
                        <h6 class="fw-bold mb-2 text-gradient" style="font-size: 1.1rem;">@Model.NominaActual.Empleado?.Nombre @Model.NominaActual.Empleado?.Apellidos</h6>
                        <p class="small mb-0 text-muted">
                            <strong>DNI:</strong> @Model.NominaActual.Empleado?.Dni
                        </p>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-secondary-custom">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                            <span class="text-muted small fw-bold text-uppercase">Datos de Afiliación</span>
                        </div>
                        <h6 class="fw-bold mb-2" style="font-size: 1rem;">Nº SS: @Model.NominaActual.Empleado?.NumSeguridadSocial</h6>
                        <p class="small mb-0 text-muted">
                            <strong>Grupo Cotización:</strong> @Model.NominaActual.Empleado?.GrupoCotizacion
                        </p>
                    </div>
                </div>
            </div>

            <!-- Tabla de conceptos -->
            <div class="table-responsive mb-4">
                <table class="table table-payslip mb-0">
                    <thead>
                        <tr>
                            <th style="color: black !important; font-weight: 700; text-shadow: 0 1px 2px rgba(0,0,0,0.3);">Conceptos Retributivos</th>
                            <th style="color: black !important; font-weight: 700; text-shadow: 0 1px 2px rgba(0,0,0,0.3);" class="text-end">Devengos</th>
                            <th style="color: black !important; font-weight: 700; text-shadow: 0 1px 2px rgba(0,0,0,0.3);" class="text-end">Deducciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var det in Model.NominaActual.NominaDetalles.OrderBy(d => d.Tipo))
                        {
                            <tr>
                                <td class="concepto-nombre">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="me-2 text-secondary-custom">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                    </svg>
                                    @det.ConceptoNombre
                                </td>
                                <td class="text-end">
                                    @if (det.Tipo == 1)
                                    {
                                        <span class="importe-devengo">
                                            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="me-1">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                                            </svg>
                                            @det.Importe.ToString("N2") €
                                        </span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (det.Tipo == 2)
                                    {
                                        <span class="importe-deduccion">
                                            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="me-1">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>
                                            </svg>
                                            @det.Importe.ToString("N2") €
                                        </span>
                                    }
                                </td>
                            </tr>
                        }

                        <tr class="total-row">
                            <td class="text-end text-uppercase">Totales:</td>
                            <td class="text-end">@Model.NominaActual.TotalDevengado.ToString("N2") €</td>
                            <td class="text-end">@Model.NominaActual.TotalDeducciones.ToString("N2") €</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Líquido a percibir -->
            <div class="liquido-percibir-box">
                <div class="row align-items-center">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <div class="liquido-label">
                            <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="me-2">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            Líquido a Percibir
                        </div>
                        <p class="text-white-50 mb-0 small">Importe neto a cobrar</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <div class="liquido-amount">@Model.NominaActual.LiquidoApercibir.ToString("N2") €</div>
                    </div>
                </div>
            </div>

            <!-- Bases de cotización e IRPF -->
            <div class="bases-section">
                <h6>
                    <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="me-2">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                    </svg>
                    Bases de Cotización e I.R.P.F.
                </h6>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="base-item">
                            <span class="base-label">Base Cont. Comunes</span>
                            <div class="base-value">@Model.NominaActual.BaseCotizacionCc.ToString("N2") €</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="base-item">
                            <span class="base-label">Base Cont. Profesionales</span>
                            <div class="base-value">@Model.NominaActual.BaseCotizacionCp.ToString("N2") €</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="base-item">
                            <span class="base-label">Base Sujeta I.R.P.F. (@Model.NominaActual.PorcentajeIrpf%)</span>
                            <div class="base-value">@Model.NominaActual.BaseIrpf.ToString("N2") €</div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    }
    else
    {
        <div class="alert bg-white border shadow-sm text-center p-5 mx-auto" style="max-width: 800px; border-radius: 1rem;">
            <div class="mb-3">
                <svg width="48" height="48" fill="none" stroke="#9ca3af" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
            </div>
            <h5 class="fw-bold text-dark">No hay registros</h5>
            <p class="text-muted mb-0">No se ha encontrado ninguna nómina generada para dicho periodo.</p>
        </div>
    }

</div>