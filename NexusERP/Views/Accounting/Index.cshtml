@model DashboardFinancieroViewModel
@{
    ViewData["Title"] = "Dashboard Financiero";
    ViewData["ActiveMenu"] = "accounting";
}

<link rel="stylesheet" href="~/css/accounting-styles.css" asp-append-version="true" />

<main class="bg-light pb-5 min-vh-100">
    <div class="container-fluid px-4 pt-4">

        <!-- Page Header -->
        <div class="mb-4">
            <h1 class="h4 fw-bold text-dark mb-1">Contabilidad y Finanzas</h1>
            <p class="text-muted small">Gestión financiera y registros contables</p>
        </div>

        <!-- Navegación del Módulo -->
        <div class="mb-4">
            <div class="acct-nav-container">
                <a asp-action="Index" class="acct-nav-link active">
                    <i class="fas fa-chart-line"></i> Dashboard
                </a>
                <a asp-action="PlanContable" class="acct-nav-link">
                    <i class="fas fa-file-alt"></i> Plan Contable
                </a>
                <a asp-action="Diario" class="acct-nav-link">
                    <i class="far fa-calendar-alt"></i> Libro Diario
                </a>
                <a asp-action="Mayor" class="acct-nav-link">
                    <i class="fas fa-search"></i> Libro Mayor
                </a>
            </div>
        </div>

        <!-- TARJETAS DE KPIs -->
        <div class="row g-4 mb-4">
            <!-- Ingresos -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-body p-4 d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted small fw-medium mb-1">Total Ingresos (Año)</p>
                            <h3 class="fw-bold mb-0 text-info">@Model.TotalIngresos.ToString("N2") €</h3>
                        </div>
                        <div class="bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center" style="width: 54px; height: 54px;">
                            <i class="fas fa-arrow-trend-up fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Gastos -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-body p-4 d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted small fw-medium mb-1">Total Gastos (Año)</p>
                            <h3 class="fw-bold mb-0 text-danger">@Model.TotalGastos.ToString("N2") €</h3>
                        </div>
                        <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 54px; height: 54px;">
                            <i class="fas fa-arrow-trend-down fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Beneficio Neto -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-body p-4 d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted small fw-medium mb-1">Resultado Neto</p>
                            @{
                                string colorBeneficio = Model.BeneficioNeto >= 0 ? "text-success" : "text-danger";
                            }
                            <h3 class="fw-bold mb-0 @colorBeneficio">@Model.BeneficioNeto.ToString("N2") €</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 54px; height: 54px;">
                            <i class="fas fa-piggy-bank fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- GRÁFICOS -->
        <div class="row g-4">

            <!-- Gráfico de Donut (Gastos por Naturaleza) -->
            <div class="col-md-5">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-body p-4">
                        <h5 class="fw-bold text-dark mb-1">Gastos por Naturaleza</h5>
                        <p class="text-muted small mb-4">Distribución porcentual de los gastos</p>

                        @if (Model.TotalGastos > 0)
                        {
                            <div style="height: 300px; display: flex; justify-content: center;">
                                <!-- INYECCIÓN DE DATOS VÍA DATA-ATTRIBUTES -->
                                <canvas id="chartGastos"
                                        data-labels='@Html.Raw(Json.Serialize(Model.NombresCuentasGasto))'
                                        data-values='@Html.Raw(Json.Serialize(Model.ImportesGasto))'>
                                </canvas>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="fas fa-chart-pie fs-1 text-light mb-3"></i>
                                <p>No hay gastos registrados este año.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Gráfico de Barras (Evolución) -->
            <div class="col-md-7">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-body p-4">
                        <h5 class="fw-bold text-dark mb-1">Ingresos vs Gastos</h5>
                        <p class="text-muted small mb-4">Comparativa mensual del ejercicio actual</p>

                        <div style="height: 300px;">
                            <!-- INYECCIÓN DE DATOS VÍA DATA-ATTRIBUTES -->
                            <canvas id="chartEvolucion"
                                    data-labels='@Html.Raw(Json.Serialize(Model.Meses))'
                                    data-ingresos='@Html.Raw(Json.Serialize(Model.IngresosMensuales))'
                                    data-gastos='@Html.Raw(Json.Serialize(Model.GastosMensuales))'>
                            </canvas>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</main>

@section Scripts {
    <script src="~/js/dashboard-financiero.js" asp-append-version="true"></script>
}