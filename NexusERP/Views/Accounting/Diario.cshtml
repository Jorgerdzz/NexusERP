@model List<NexusERP.ViewModels.AsientoViewModel>
@{
    ViewData["Title"] = "Libro Diario";
    ViewData["ActiveMenu"] = "accounting";
}

<main class="bg-light pb-5 min-vh-100">
    <div class="container-fluid px-4 pt-4 dashboard-container">

        <div class="d-flex justify-content-between align-items-end mb-4 kpi-wrapper">
            <div>
                <h2 class="fw-bold mb-1 text-dark-heading h3">Libro Diario</h2>
                <p class="text-muted mb-0 small">Registro cronológico de todos los movimientos contables</p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary d-none d-md-flex align-items-center gap-2 px-3 shadow-sm rounded-3">
                    <svg style="width: 18px; height: 18px" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                    Exportar
                </button>
                <button class="btn btn-primary btn-brand d-flex align-items-center gap-2 px-3 shadow-sm rounded-3" data-bs-toggle="modal" data-bs-target="#modalNuevoAsiento">
                    <svg style="width: 18px; height: 18px" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Nuevo Asiento
                </button>
            </div>
        </div>

        <div class="mb-4 kpi-wrapper" style="animation-delay: 0.1s;">
            <div class="acct-nav-container custom-nav-pills d-inline-flex p-1 rounded-4 shadow-sm bg-white border">
                <a asp-action="Index" class="acct-nav-link rounded-pill px-4 py-2 text-decoration-none fw-medium text-muted transition-all hover-bg-light">
                    <i class="fas fa-chart-line me-2"></i> Dashboard
                </a>
                <a asp-action="PlanContable" class="acct-nav-link rounded-pill px-4 py-2 text-decoration-none fw-medium text-muted transition-all hover-bg-light">
                    <i class="fas fa-file-alt me-2"></i> Plan Contable
                </a>
                <a asp-action="Diario" class="acct-nav-link active rounded-pill px-4 py-2 text-decoration-none fw-medium transition-all">
                    <i class="far fa-calendar-alt me-2"></i> Libro Diario
                </a>
                <a asp-action="Mayor" class="acct-nav-link rounded-pill px-4 py-2 text-decoration-none fw-medium text-muted transition-all hover-bg-light">
                    <i class="fas fa-search me-2"></i> Libro Mayor
                </a>
            </div>
        </div>

        <div class="card bg-white border border-light-subtle shadow-sm rounded-4 mb-4 kpi-wrapper" style="animation-delay: 0.2s;">
            <div class="card-body p-3 d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div class="d-flex flex-wrap gap-3 align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small fw-medium"><i class="far fa-calendar text-secondary me-1"></i> Desde:</span>
                        <input type="date" class="form-control custom-input py-1" style="width: 140px;">
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small fw-medium"><i class="far fa-calendar text-secondary me-1"></i> Hasta:</span>
                        <input type="date" class="form-control custom-input py-1" style="width: 140px;">
                    </div>
                    <button class="btn btn-light-custom shadow-sm px-3 rounded-3 d-flex align-items-center gap-2" style="padding-top: 0.35rem; padding-bottom: 0.35rem;">
                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"></path>
                        </svg>
                        Filtrar
                    </button>
                </div>
                <div class="text-muted small fw-semibold bg-light border px-3 py-2 rounded-pill d-flex align-items-center gap-2">
                    <span class="badge bg-secondary rounded-pill">@Model.Count()</span> Asientos en el periodo
                </div>
            </div>
        </div>

        <div class="d-flex flex-column gap-3 mb-5">
            @if (Model.Any())
            {
                var delay = 0.3;
                @foreach (var asiento in Model)
                {
                    <details class="custom-details-card bg-white rounded-4 shadow-sm border border-light-subtle kpi-wrapper" style="animation-delay: @(delay)s;">

                        <summary class="asiento-summary d-flex flex-wrap align-items-center justify-content-between p-3 rounded-4 user-select-none cursor-pointer">

                            <div class="d-flex align-items-center gap-3 mb-2 mb-md-0">
                                <div class="icon-box shadow-sm flex-shrink-0" style="width: 42px; height: 42px;">
                                    <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                        <line x1="16" y1="2" x2="16" y2="6"></line>
                                        <line x1="8" y1="2" x2="8" y2="6"></line>
                                        <line x1="3" y1="10" x2="21" y2="10"></line>
                                    </svg>
                                </div>

                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <span class="fw-bold text-dark-heading fs-6 font-monospace">@asiento.NumeroAsiento</span>
                                        <span class="badge bg-light text-secondary border fw-medium px-2 py-1">@asiento.Fecha.ToString("d/M/yyyy")</span>
                                    </div>
                                    <span class="text-muted small fw-medium">
                                        @asiento.Glosa
                                    </span>
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-3">
                                <span class="badge bg-light text-secondary border fw-medium px-3 py-2 rounded-pill shadow-sm d-none d-sm-inline-block">
                                    <i class="fas fa-tag me-1 opacity-50"></i> @asiento.Origen
                                </span>

                                @if (asiento.Cuadrado)
                                {
                                    <span class="badge-soft-success d-flex align-items-center gap-1 shadow-sm px-3 py-2 rounded-pill fw-medium border">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        CUADRADO
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-soft-danger d-flex align-items-center gap-1 shadow-sm px-3 py-2 rounded-pill fw-medium border">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
                                        </svg>
                                        DESCUADRADO
                                    </span>
                                }

                                <div class="details-chevron d-flex align-items-center justify-content-center bg-light rounded-circle border shadow-sm text-secondary" style="width: 34px; height: 34px;">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="6 9 12 15 18 9"></polyline>
                                    </svg>
                                </div>
                            </div>
                        </summary>

                        <div class="asiento-body bg-white border-top">
                            <div class="table-responsive">
                                <table class="table table-hover table-borderless custom-table w-100 m-0">
                                    <thead class="bg-light text-muted small fw-semibold text-uppercase" style="letter-spacing: 0.05em;">
                                        <tr>
                                            <th class="ps-4 py-3" style="width: 15%;">Cuenta</th>
                                            <th class="py-3">Nombre de la Cuenta</th>
                                            <th class="text-end py-3" style="width: 20%;">Debe</th>
                                            <th class="text-end pe-4 py-3" style="width: 20%;">Haber</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var apunte in asiento.Apuntes)
                                        {
                                            <tr class="align-middle">
                                                <td class="ps-4 py-3">
                                                    <span class="font-monospace fw-bold text-dark-heading">@apunte.CuentaCodigo</span>
                                                </td>
                                                <td class="text-muted fw-medium py-3 d-flex align-items-center">
                                                    <span style="font-size: 0.5rem;" class="text-secondary opacity-50 me-2">●</span>
                                                    @apunte.CuentaNombre
                                                </td>
                                                <td class="text-end fw-semibold text-dark py-3">
                                                    @(apunte.Debe > 0 ? apunte.Debe.ToString("N2") + " €" : "-")
                                                </td>
                                                <td class="text-end fw-semibold text-dark pe-4 py-3">
                                                    @(apunte.Haber > 0 ? apunte.Haber.ToString("N2") + " €" : "-")
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot class="bg-light-subtle row-totales">
                                        <tr>
                                            <td colspan="2" class="ps-4 fw-bold text-dark-heading text-end py-3 text-uppercase small" style="letter-spacing: 0.05em;">Sumas Totales</td>
                                            <td class="text-end fw-bold py-3 text-brand fs-6">@asiento.TotalDebe.ToString("N2") €</td>
                                            <td class="text-end fw-bold pe-4 py-3 text-brand fs-6">@asiento.TotalHaber.ToString("N2") €</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </details>
                    delay += 0.05;
                }
            }
            else
            {
                <div class="empty-state-card text-center p-5 mx-auto kpi-wrapper mt-3" style="max-width: 600px; animation-delay: 0.3s;">
                    <div class="mb-4">
                        <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center"
                             style="width: 80px; height: 80px; background: linear-gradient(135deg, rgba(59, 155, 173, 0.1), rgba(59, 155, 173, 0.05)); color: #3b9bad;">
                            <svg width="36" height="36" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                            </svg>
                        </div>
                    </div>

                    <h5 class="fw-bold text-dark-heading mb-2">Libro Diario Vacío</h5>
                    <p class="text-muted mb-4">
                        Aún no hay asientos contables registrados. Genera una factura o nómina para que se registren automáticamente los movimientos.
                    </p>

                    <button class="btn btn-primary btn-brand d-inline-flex align-items-center gap-2 px-4 shadow-sm rounded-pill" data-bs-toggle="modal" data-bs-target="#modalNuevoAsiento">
                        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        Crear Asiento Manual
                    </button>
                </div>
            }
        </div>
    </div>
</main>

<div class="modal fade" id="modalNuevoAsiento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 1rem;">
            <div class="modal-header border-bottom-0 pb-0 pt-4 px-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-box shadow-sm flex-shrink-0" style="width: 40px; height: 40px;">
                        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                        </svg>
                    </div>
                    <h5 class="modal-title fw-bold text-dark-heading mb-0">Nuevo Asiento Manual</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body px-4 py-5 text-center">
                <h6 class="fw-bold text-dark-heading">Próximamente</h6>
                <p class="text-muted small mb-0 mx-auto" style="max-width: 300px;">
                    La creación de asientos manuales estará disponible en la próxima actualización del módulo financiero.
                </p>
            </div>

            <div class="modal-footer border-top px-4 py-3 bg-light" style="border-bottom-left-radius: 1rem; border-bottom-right-radius: 1rem;">
                <button type="button" class="btn btn-light-custom px-4 mx-auto w-100" data-bs-dismiss="modal">Entendido</button>
            </div>
        </div>
    </div>
</div>