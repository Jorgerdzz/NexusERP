@model NexusERP.ViewModels.MayorViewModel
@{
    ViewData["Title"] = "Libro Mayor";
    ViewData["ActiveMenu"] = "accounting";
}

<link rel="stylesheet" href="~/css/accounting-styles.css" asp-append-version="true" />

<main class="bg-light pb-5 min-vh-100">
    <div class="container-fluid px-4 pt-4">

        <div class="mb-4">
            <h1 class="h4 fw-bold text-dark mb-1">Contabilidad y Finanzas</h1>
            <p class="text-muted small">Gestión financiera y registros contables</p>
        </div>

        <div class="mb-4">
            <div class="acct-nav-container">
                <a asp-action="Index" class="acct-nav-link">
                    <i class="fas fa-chart-line"></i> Dashboard
                </a>
                <a asp-action="PlanContable" class="acct-nav-link">
                    <i class="fas fa-file-alt"></i> Plan Contable
                </a>
                <a asp-action="Diario" class="acct-nav-link">
                    <i class="far fa-calendar-alt"></i> Libro Diario
                </a>
                <a asp-action="Mayor" class="acct-nav-link active">
                    <i class="fas fa-search"></i> Libro Mayor
                </a>
            </div>
        </div>

        <div class="card border-0 shadow-sm" style="border-radius: 0.75rem;">
            <div class="card-body p-4 p-md-5">

                <div class="mb-4">
                    <h4 class="fw-semibold text-dark mb-1 fs-5">Libro Mayor</h4>
                    <p class="text-muted small mb-0">Auditoría de movimientos y saldo acumulado por cuenta</p>
                </div>

                <form asp-action="Mayor" method="get" class="mb-5">
                    <div class="row align-items-end g-3">
                        <div class="col-md-5">
                            <label class="form-label fw-medium text-secondary small mb-1">Seleccione Cuenta</label>
                            <select asp-for="CuentaIdSeleccionada" asp-items="Model.CuentasDisponibles" class="form-select bg-white border-light-subtle shadow-sm" onchange="this.form.submit()">
                                <option value="">-- Elija una cuenta para ver su mayor --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-medium text-secondary small mb-1">Fecha Desde</label>
                            <input type="date" asp-for="FechaDesde" class="form-control bg-white border-light-subtle shadow-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-medium text-secondary small mb-1">Fecha Hasta</label>
                            <input type="date" asp-for="FechaHasta" class="form-control bg-white border-light-subtle shadow-sm" />
                        </div>
                        <div class="col-md-1">
                            <button type="submit" class="btn btn-dark-custom w-100 shadow-sm">Filtrar</button>
                        </div>
                    </div>
                </form>

                @if (Model.CuentaIdSeleccionada.HasValue)
                {
                    <div class="table-responsive rounded-3 border">
                        <table class="table table-accounting mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Fecha</th>
                                    <th>Asiento</th>
                                    <th>Concepto</th>
                                    <th class="text-end">Debe</th>
                                    <th class="text-end">Haber</th>
                                    <th class="text-end pe-4">Saldo Acumulado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var mov in Model.Movimientos)
                                {
                                    // La fila de Saldo Inicial la ponemos de color azulito claro como pediste
                                    string bgClass = mov.EsSaldoInicial ? "bg-secondary-light" : "bg-white hover-bg-light";
                                    string textClass = mov.EsSaldoInicial ? "fw-medium text-secondary-custom" : "text-dark";

                                    <tr class="@bgClass">
                                        <td class="ps-4 text-secondary" style="font-size: 0.9rem;">@mov.Fecha.ToString("dd/MM/yyyy")</td>
                                        <td class="fw-bold @textClass" style="font-size: 0.9rem;">@mov.AsientoNumero</td>
                                        <td class="@textClass" style="font-size: 0.95rem;">@mov.Concepto</td>

                                        <td class="text-end fw-medium text-dark">
                                            @(mov.Debe > 0 ? "€" + mov.Debe.ToString("N2") : "-")
                                        </td>
                                        <td class="text-end fw-medium text-dark">
                                            @(mov.Haber > 0 ? "€" + mov.Haber.ToString("N2") : "-")
                                        </td>

                                        <td class="text-end fw-bold text-dark pe-4" style="font-size: 1.05rem;">
                                            €@mov.SaldoAcumulado.ToString("N2")
                                        </td>
                                    </tr>
                                }

                                @if (!Model.Movimientos.Any(m => !m.EsSaldoInicial))
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">No hay movimientos en este periodo.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-4 p-4 bg-secondary-light rounded-3 d-flex align-items-center justify-content-between" style="border: 1px solid rgba(59, 155, 173, 0.2);">
                        <div>
                            <p class="text-muted small mb-0 fw-medium">Saldo Final de la Cuenta</p>
                            <p class="fs-3 fw-bold text-primary-custom mb-0 mt-1">€@Model.SaldoFinal.ToString("N2")</p>
                        </div>
                        <div class="text-end">
                            <p class="text-secondary fw-medium mb-0" style="font-size: 0.95rem;">@Model.NombreCuentaSeleccionada</p>
                            <p class="text-muted small mb-0 mt-1">
                                Periodo: @Model.FechaDesde.ToString("dd/MM/yyyy") - @Model.FechaHasta.ToString("dd/MM/yyyy")
                            </p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-search fs-1 text-light mb-3"></i>
                        <h5 class="fw-bold text-dark">Seleccione una cuenta</h5>
                        <p class="text-muted">Utilice el desplegable superior para ver el historial de movimientos.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</main>