@model NexusERP.Models.Cliente

@{
    ViewData["Title"] = $"Cliente - {Model.RazonSocial}";
    ViewData["ActiveMenu"] = "Facturacion";
}

<div class="container-fluid py-4 min-vh-100" style="background-color: #f8fafc; animation: fadeIn 0.5s ease-out forwards;">
    
    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-end mb-4 bg-white p-4 rounded-4 shadow-sm border border-light" style="position: relative; overflow: hidden;">
        <div style="position: absolute; top:0; left:0; right:0; height: 4px; background: linear-gradient(90deg, var(--secondary-color), var(--success-color));"></div>
        <div class="d-flex align-items-center gap-4">
            <a href="javascript:history.back()" class="btn btn-link text-decoration-none text-muted p-0 d-flex align-items-center justify-content-center bg-light rounded-circle" style="width: 40px; height: 40px; transition: all 0.2s ease;" title="Volver al listado">
                <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                </svg>
            </a>
            <div>
                <h2 class="fw-bold mb-0 text-dark-heading d-flex align-items-center gap-3" style="font-size: 1.75rem; letter-spacing: -0.5px;">
                    @Model.RazonSocial
                    @if (Model.Activo)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-1 fw-medium" style="font-size: 0.85rem; letter-spacing: 0;">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-1 fw-medium" style="font-size: 0.85rem; letter-spacing: 0;">Inactivo</span>
                    }
                </h2>
                <p class="text-muted mb-0 mt-1 d-flex align-items-center gap-2">
                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                    </svg>
                    Cliente de la empresa
                </p>
            </div>
        </div>
        <div>
            <form asp-controller="Facturacion" asp-action="NuevaFactura" method="get">
                <input type="hidden" name="clienteId" value="@Model.Id" />
                <button type="submit" class="btn text-white d-flex align-items-center gap-2 px-4 py-2 fw-medium rounded-3 transition-hover shadow-sm" style="background-color: var(--secondary-color);">
                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Emitir Factura
                </button>
            </form>
        </div>
    </div>

    <div class="row g-4 d-flex align-items-stretch">
        
        <!-- COLUMNA IZQUIERDA: RESUMEN Y CONTACTO -->
        <div class="col-lg-4 d-flex flex-column gap-4">
            
            <!-- TARJETA AVATAR -->
            <div class="card bg-white rounded-4 shadow-sm border border-light" style="position: relative; overflow: hidden;">
                <div style="height: 100px; background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));"></div>
                <div class="card-body px-4 pb-4 pt-0 text-center">
                    <div class="position-relative d-inline-block shadow-sm rounded-circle mb-3" style="margin-top: -40px; background-color: white; padding: 4px;">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; background: linear-gradient(135deg, #f1f5f9, #e2e8f0); border: 2px solid white;">
                            <span class="fs-2 fw-bold text-secondary-custom">
                                @(Model.RazonSocial.Length > 1 ? Model.RazonSocial.Substring(0, 2).ToUpper() : Model.RazonSocial.ToUpper())
                            </span>
                        </div>
                    </div>
                    
                    <h5 class="fw-bold mb-1 text-dark-heading">@Model.RazonSocial</h5>
                    <p class="text-muted mb-3 small d-flex align-items-center justify-content-center gap-2">
                        <span class="badge bg-light text-dark border px-2 py-1">CIF/NIF: @Model.CifNif</span>
                    </p>
                </div>
            </div>

            <!-- TARJETA CONTACTO -->
            <div class="card bg-white rounded-4 shadow-sm border border-light flex-grow-1">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h6 class="fw-bold text-dark-heading mb-0 text-uppercase tracking-wide" style="font-size: 0.85rem;">Información de Contacto</h6>
                        <button class="btn btn-sm btn-link text-decoration-none text-muted p-0" title="Editar contacto">
                            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
                            </svg>
                        </button>
                    </div>
                    
                    <ul class="list-unstyled mb-0 d-flex flex-column gap-3">
                        <li class="d-flex align-items-start gap-3">
                            <div class="p-2 bg-light rounded-3 text-muted">
                                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                </svg>
                            </div>
                            <div>
                                <span class="d-block text-muted small fw-medium">Correo Electrónico</span>
                                <span class="d-block fw-semibold text-dark">
                                    @if (!string.IsNullOrEmpty(Model.Email))
                                    {
                                        <a href="mailto:@Model.Email" class="text-decoration-none text-dark">@Model.Email</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">No especificado</span>
                                    }
                                </span>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
            
        </div>

        <!-- COLUMNA DERECHA: HISTORIAL DE FACTURAS -->
        <div class="col-lg-8 d-flex flex-column gap-4">
            
            <div class="card bg-white rounded-4 shadow-sm border border-light flex-grow-1">
                <div class="card-header bg-white border-bottom-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-3">
                        <div class="p-2 text-white rounded-3 shadow-sm" style="background-color: var(--secondary-color);">
                            <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                        </div>
                        <h5 class="fw-bold mb-0 text-dark-heading">Historial de Facturas Emitidas</h5>
                    </div>
                </div>

                <div class="card-body p-4 pt-3">
                    <div class="table-responsive rounded-3 border mt-2">
                        <table class="table table-hover table-borderless align-middle table-minimalist w-100 mb-0">
                            <thead class="bg-light text-muted small fw-semibold text-uppercase" style="letter-spacing: 0.05em;">
                                <tr>
                                    <th class="ps-4 py-3" style="width: 20%;">Nº Factura</th>
                                    <th class="py-3 text-center" style="width: 25%;">Fecha Emisión</th>
                                    <th class="text-end py-3" style="width: 25%;">Importe Total</th>
                                    <th class="text-center py-3" style="width: 15%;">Estado</th>
                                    <th class="text-center pe-4 py-3" style="width: 15%;">Ver</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Facturas != null && Model.Facturas.Any())
                                {
                                    @foreach (var factura in Model.Facturas.OrderByDescending(f => f.FechaEmision))
                                    {
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <span class="font-monospace fw-bold text-dark-heading">@factura.NumeroFactura</span>
                                            </td>
                                            <td class="text-center py-3 text-secondary small fw-medium">
                                                @factura.FechaEmision.ToString("dd/MM/yyyy")
                                            </td>
                                            <td class="text-end py-3 fw-bold" style="color: var(--secondary-color);">
                                                @factura.TotalFactura.ToString("N2") €
                                            </td>
                                            <td class="text-center py-3">
                                                @if (factura.Estado == "Pendiente")
                                                {
                                                    <span class="badge rounded-pill fw-medium border px-3 py-1" style="background-color: #fff8e6; border-color: #fde68a !important; color: #b45309;">Pendiente</span>
                                                }
                                                else
                                                {
                                                    <span class="badge rounded-pill fw-medium border px-3 py-1" style="background-color: #e8f8f0; border-color: #a7f3d0 !important; color: #065f46;">Pagada</span>
                                                }
                                            </td>
                                            <td class="text-center pe-4 py-3">
                                                <a asp-controller="Facturacion" asp-action="Details" asp-route-id="@factura.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3 fw-medium bg-white" title="Ver Factura" style="border-color: #e2e8f0; color: #475569;">
                                                    <i class="far fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <div class="text-muted d-flex flex-column align-items-center">
                                                <svg width="40" height="40" fill="none" stroke="#cbd5e1" viewBox="0 0 24 24" class="mb-3" stroke-width="1.5">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                                </svg>
                                                <h6 class="fw-bold text-dark mb-1">Sin facturas</h6>
                                                <span class="small">Este cliente aún no tiene facturas emitidas.</span>
                                                
                                                <form asp-controller="Facturacion" asp-action="NuevaFactura" method="get" class="mt-3">
                                                    <input type="hidden" name="clienteId" value="@Model.Id" />
                                                    <button type="submit" class="btn btn-outline-secondary btn-sm shadow-sm rounded-pill px-3">Emitir Primera Factura</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

