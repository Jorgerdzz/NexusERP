@model List<Cliente>
@{
    ViewData["Title"] = "Directorio de Clientes";
    ViewData["ActiveMenu"] = "Facturacion";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
    <div>
        <a asp-controller="Facturacion" asp-action="Index" class="btn btn-link text-decoration-none text-muted d-flex align-items-center gap-2 p-0 px-2 py-1 btn-volver">
            <svg style="width: 16px; height: 16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Volver al panel
        </a>
    </div>
</div>

<main class="bg-light pb-5 min-vh-100">
    <div class="container-fluid px-4 pt-4">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-end mb-4 kpi-wrapper">
            <div>
                <h1 class="h4 fw-bold text-dark mb-1">Directorio de Clientes</h1>
                <p class="text-muted small mb-0">Gestión de la cartera de clientes, información fiscal y estado.</p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary d-flex align-items-center gap-2 px-3 shadow-sm rounded-3" style="background-color: var(--secondary-color); border-color: var(--secondary-color);" data-bs-toggle="modal" data-bs-target="#modalCrearCliente">
                    <svg style="width: 18px; height: 18px" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Nuevo Cliente
                </button>
            </div>
        </div>

        <!-- Tabla de Clientes -->
        <div class="card border-0 shadow-sm kpi-wrapper" style="border-radius: 16px; overflow: hidden; animation-delay: 0.1s;">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold text-dark mb-0">Listado de Clientes</h5>
            </div>
            
            <div class="table-responsive">
                <table class="table table-minimalist w-100 mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Razón Social</th>
                            <th>CIF/NIF</th>
                            <th>Email</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cliente in Model)
                        {
                            <tr>
                                <td class="fw-bold text-dark ps-4">
                                    @cliente.RazonSocial
                                </td>
                                <td class="fw-medium text-muted">
                                    @cliente.CifNif
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(cliente.Email))
                                    {
                                        <a href="mailto:@cliente.Email" class="text-decoration-none text-muted">@cliente.Email</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted"><i class="fas fa-minus"></i></span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (cliente.Activo)
                                    {
                                        <span class="badge-status status-activo">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status status-inactivo">Inactivo</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Details" asp-route-id="@cliente.Id" class="btn-action-icon btn-action-details" title="Ver Detalles">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                                <circle cx="12" cy="12" r="3"></circle>
                                            </svg>
                                        </a>

                                        <button type="button" class="btn-action-icon btn-action-edit" title="Editar"
                                                data-bs-toggle="modal" data-bs-target="#modalEditarCliente"
                                                data-id="@cliente.Id"
                                                data-razon="@cliente.RazonSocial"
                                                data-cif="@cliente.CifNif"
                                                data-email="@cliente.Email"
                                                data-activo="@cliente.Activo.ToString().ToLower()">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                            </svg>
                                        </button>

                                        <form asp-controller="Clientes" asp-action="Delete" asp-route-id="@cliente.Id" method="post" class="m-0" onsubmit="return confirm('¿Estás seguro de que deseas eliminar este cliente?');">
                                            <button type="submit" class="btn-action-icon btn-action-delete" title="Eliminar">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <polyline points="3 6 5 6 21 6"></polyline>
                                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                                    <line x1="10" y1="11" x2="10" y2="17"></line>
                                                    <line x1="14" y1="11" x2="14" y2="17"></line>
                                                </svg>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mb-3">
                                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                        <circle cx="9" cy="7" r="4"></circle>
                                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                    </svg>
                                    <h6 class="fw-bold text-dark mb-1">Sin clientes registrados</h6>
                                    <p class="text-muted small mb-0">No hay clientes actualmente en el sistema. Puedes añadir uno nuevo hacienco click en el botón de arriba.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</main>

<partial name="_ClientesModals" />

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // Lógica para rellenar el modal de Editar dinámicamente
            const editButtons = document.querySelectorAll('.btn-edit-cliente');

            editButtons.forEach(button => {
                button.addEventListener('click', function () {
                    // 1. Extraemos los datos del botón
                    const id = this.getAttribute('data-id');
                    const razon = this.getAttribute('data-razon');
                    const cif = this.getAttribute('data-cif');
                    const email = this.getAttribute('data-email');
                    const activo = this.getAttribute('data-activo') === 'true'; // Convertir string a boolean

                    // 2. Inyectamos los datos en el formulario del Modal
                    document.getElementById('edit-id').value = id;
                    document.getElementById('edit-razon').value = razon;
                    document.getElementById('edit-cif').value = cif;
                    document.getElementById('edit-email').value = email;
                    document.getElementById('edit-activo').checked = activo;
                });
            });

        });
    </script>
}
