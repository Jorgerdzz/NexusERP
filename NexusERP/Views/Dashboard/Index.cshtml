@model NexusERP.ViewModels.HomeDashboardViewModel
@{
    ViewData["Title"] = "Panel de Control";
    ViewData["ActiveMenu"] = "home";
}

<link rel="stylesheet" href="~/css/home-dashboard.css" asp-append-version="true" />

<main class="bg-light pb-5 min-vh-100">
    <div class="container-fluid px-4 pt-4">

        <div class="mb-4">
            <h1 class="h4 fw-bold text-dark mb-1">¡Hola, @Model.NombreUsuario!</h1>
            <p class="text-muted small">Resumen financiero general del año @DateTime.Now.Year.</p>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="card card-kpi card-kpi-success h-100 p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <p class="text-muted small fw-semibold text-uppercase mb-0">Ingresos Anuales</p>
                        <div class="icon-kpi" style="background: linear-gradient(135deg, #e8f8f0, #ffffff);">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                            </svg>
                        </div>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0 text-dark-heading">
                            @Model.TotalFacturadoAnual.ToString("N2") <span class="fs-6 fw-normal text-muted">€</span>
                        </h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card card-kpi card-kpi-danger h-100 p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <p class="text-muted small fw-semibold text-uppercase mb-0">Gasto Salarial</p>
                        <div class="icon-kpi" style="background: linear-gradient(135deg, #fef2f2, #ffffff);">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path>
                            </svg>
                        </div>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0 text-dark-heading">
                            @Model.TotalGastoSalarial.ToString("N2") <span class="fs-6 fw-normal text-muted">€</span>
                        </h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card card-kpi card-kpi-primary h-100 p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <p class="text-muted small fw-semibold text-uppercase mb-0">Balance Neto</p>
                        <div class="icon-kpi" style="background: linear-gradient(135deg, #e0f4f7, #ffffff);">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--secondary-color, #3b9bad)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="5" width="20" height="14" rx="2"></rect>
                                <line x1="2" y1="10" x2="22" y2="10"></line>
                            </svg>
                        </div>
                    </div>
                    <div>
                        @{
                            string colorBalance = Model.Balance >= 0 ? "text-success" : "text-danger";
                        }
                        <h3 class="fw-bold mb-0 @colorBalance">
                            @Model.Balance.ToString("N2") <span class="fs-6 fw-normal text-muted">€</span>
                        </h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card card-kpi card-kpi-warning h-100 p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <p class="text-muted small fw-semibold text-uppercase mb-0">Facturas Pendientes</p>
                        <div class="icon-kpi" style="background: linear-gradient(135deg, #fffbeb, #ffffff);">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                <polyline points="14 2 14 8 20 8"></polyline>
                                <circle cx="12" cy="13" r="2"></circle>
                                <path d="M12 11v2"></path>
                            </svg>
                        </div>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0 text-dark-heading">
                            @Model.FacturasPendientes <span class="fs-6 fw-normal text-muted">docs</span>
                        </h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="mb-2">
            <h4 class="h5 fw-bold text-dark mb-4">Acciones Recomendadas</h4>

            @if (!Model.EstaConfigurado)
            {
                <div class="alert bg-white border border-primary border-opacity-25 shadow-sm d-flex gap-3 align-items-start rounded-4 p-4 mb-4 position-relative overflow-hidden kpi-card-balance">
                    <div class="position-absolute top-0 start-0 bottom-0" style="width: 4px; background-color: var(--secondary-color);"></div>
                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(59, 130, 246, 0.05)); color: var(--secondary-color);">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <div>
                        <h6 class="fw-bold text-dark mb-1">Configuración Inicial Incompleta</h6>
                        <p class="mb-0 text-muted small">Para poder emitir facturas o calcular nóminas, primero debes configurar los datos maestros de tu empresa.</p>
                    </div>
                </div>

                <div class="row g-4">
                    @if (!Model.TieneDepartamentos)
                    {

                        <div class="col-md-6">
                            <div class="action-card p-4 h-100">
                                <a asp-controller="Departaments" asp-action="Index" class="text-decoration-none">
                                    <div class="d-flex align-items-center h-100">
                                        <div class="icon-container icon-invoice me-4 shadow-sm">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                                                <polyline points="9 22 9 12 15 12 15 22"></polyline>
                                            </svg>
                                        </div>
                                        <div class="flex-grow-1">
                                            <h5 class="fw-bold mb-1 col-dark">Crear Departamentos</h5>
                                            <p class="text-muted small mb-0">Define la estructura organizativa de tu empresa.</p>
                                        </div>
                                        <div class="ms-auto text-muted icon-arrow">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="9 18 15 12 9 6"></polyline>
                                            </svg>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </div>

                    }

                    @if (!Model.TieneClientes)
                    {
                        <div class="col-md-6">
                            <div class="action-card p-4 h-100">
                                <a asp-controller="Clientes" asp-action="Index" class="text-decoration-none">
                                    <div class="d-flex align-items-center h-100">
                                        <div class="icon-container icon-invoice me-4 shadow-sm">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                                <circle cx="9" cy="7" r="4"></circle>
                                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                            </svg>
                                        </div>
                                        <div class="flex-grow-1">
                                            <h5 class="fw-bold mb-1 col-dark">Añadir Clientes</h5>
                                            <p class="text-muted small mb-0">Registra a quién vas a facturar tus servicios.</p>
                                        </div>
                                        <div class="ms-auto text-muted icon-arrow">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="9 18 15 12 9 6"></polyline>
                                            </svg>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </div>
 
                    }

                    @if (Model.TieneDepartamentos && !Model.TieneEmpleados)
                    {

                        <div class="col-md-6">
                            <div class="action-card p-4 h-100">
                                <a asp-controller="Empleados" asp-action="Index" class="text-decoration-none">
                                    <div class="d-flex align-items-center h-100">
                                        <div class="icon-container icon-invoice me-4 shadow-sm">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                                <circle cx="8.5" cy="7" r="4"></circle>
                                                <line x1="20" y1="8" x2="20" y2="14"></line>
                                                <line x1="23" y1="11" x2="17" y2="11"></line>
                                            </svg>
                                        </div>
                                        <div class="flex-grow-1">
                                            <h5 class="fw-bold mb-1 col-dark">Alta de Empleados</h5>
                                            <p class="text-muted small mb-0">Añade a tu plantilla para gestionar sus nóminas.</p>
                                        </div>
                                        <div class="ms-auto text-muted icon-arrow">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="9 18 15 12 9 6"></polyline>
                                            </svg>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </div>

                    }
                </div>
            }
            else
            {
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="action-card p-4 h-100">
                            <a asp-controller="Facturacion" asp-action="NuevaFactura" class="text-decoration-none">
                                <div class="d-flex align-items-center h-100">
                                    <div class="icon-container icon-invoice me-4 shadow-sm">
                                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                            <polyline points="14 2 14 8 20 8"></polyline>
                                            <line x1="16" y1="13" x2="8" y2="13"></line>
                                            <line x1="16" y1="17" x2="8" y2="17"></line>
                                            <polyline points="10 9 9 9 8 9"></polyline>
                                        </svg>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 class="fw-bold mb-1 col-dark">Emitir Nueva Factura</h5>
                                        <p class="text-muted small mb-0">Factura a tus clientes y genera apuntes automáticos.</p>
                                    </div>
                                    <div class="ms-auto text-muted icon-arrow">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="9 18 15 12 9 6"></polyline>
                                        </svg>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="action-card p-4 h-100">
                            <a asp-controller="Payroll" asp-action="Index" class="text-decoration-none">
                                <div class="d-flex align-items-center h-100">
                                    <div class="icon-container me-4 shadow-sm" style="background: linear-gradient(135deg, rgba(168, 85, 247, 0.1), rgba(168, 85, 247, 0.05)); color: #a855f7;">
                                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                                        </svg>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 class="fw-bold mb-1 col-dark">Calcular Nóminas</h5>
                                        <p class="text-muted small mb-0">Gestiona los recibos de salarios de este mes.</p>
                                    </div>
                                    <div class="ms-auto text-muted icon-arrow">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="9 18 15 12 9 6"></polyline>
                                        </svg>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</main>