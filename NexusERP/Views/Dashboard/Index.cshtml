@model NexusERP.ViewModels.HomeDashboardViewModel
@{
    ViewData["Title"] = "Panel de Control";
    ViewData["ActiveMenu"] = "home";
}

<main class="bg-light pb-5 min-vh-100">
    <div class="container-fluid px-4 pt-4 dashboard-container">

        <!-- Header de Bienvenida -->
        <div class="welcome-header mb-4">
            <div style="background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); border: 1px solid #e5e7eb; border-radius: 20px; padding: 2rem; box-shadow: 0 4px 16px rgba(0, 0, 0, 0.05); position: relative; overflow: hidden;">
                <div style="content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, #3b9bad, #10b981);"></div>
                <div class="d-flex align-items-center gap-3">
                    <div style="width: 64px; height: 64px; border-radius: 16px; background: linear-gradient(135deg, #e0f4f7 0%, #d1f0f5 100%); display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(59, 155, 173, 0.15);">
                        <svg width="32" height="32" fill="none" stroke="#3b9bad" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                    </div>
                    <div>
                        <h1 style="font-size: 1.75rem; font-weight: 800; background: linear-gradient(135deg, #3b9bad, #2d8599); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.25rem;">
                            ¡Hola, @Model.NombreUsuario!
                        </h1>
                        <p class="text-muted mb-0" style="font-size: 0.95rem; display: flex; align-items: center; gap: 0.5rem;">
                            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                            Bienvenido al panel general de tu ERP. Resumen financiero de @DateTime.Now.Year.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- KPIs Financieros -->
        <div class="row g-4 mb-5">
            <!-- Ingresos Anuales -->
            <div class="col-md-3">
                <div style="background: linear-gradient(135deg, #ecfdf5 0%, #ffffff 100%); border: none; border-radius: 20px; box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06); padding: 1.75rem; transition: all 0.3s ease; position: relative; overflow: hidden; height: 100%; border-left: 4px solid #10b981;" 
                     onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 24px rgba(0, 0, 0, 0.1)';" 
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 16px rgba(0, 0, 0, 0.06)';">
                    <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, #10b981, #059669);"></div>
                    <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(16, 185, 129, 0.1); color: #10b981; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                        </svg>
                    </div>
                    <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #64748b; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.5rem;">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        Ingresos Anuales
                    </p>
                    <h3 style="font-size: 1.75rem; font-weight: 900; color: #10b981; margin: 0; text-shadow: 0 2px 4px rgba(16, 185, 129, 0.1);">
                        @Model.TotalFacturadoAnual.ToString("N2") €
                    </h3>
                </div>
            </div>

            <!-- Gasto Salarial -->
            <div class="col-md-3">
                <div style="background: linear-gradient(135deg, #fef2f2 0%, #ffffff 100%); border: none; border-radius: 20px; box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06); padding: 1.75rem; transition: all 0.3s ease; position: relative; overflow: hidden; height: 100%; border-left: 4px solid #ef4444;" 
                     onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 24px rgba(0, 0, 0, 0.1)';" 
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 16px rgba(0, 0, 0, 0.06)';">
                    <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, #ef4444, #dc2626);"></div>
                    <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(239, 68, 68, 0.1); color: #ef4444; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"></path>
                        </svg>
                    </div>
                    <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #64748b; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.5rem;">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path>
                        </svg>
                        Gasto Salarial
                    </p>
                    <h3 style="font-size: 1.75rem; font-weight: 900; color: #ef4444; margin: 0; text-shadow: 0 2px 4px rgba(239, 68, 68, 0.1);">
                        @Model.TotalGastoSalarial.ToString("N2") €
                    </h3>
                </div>
            </div>

            <!-- Balance Neto -->
            <div class="col-md-3">
                <div style="background: linear-gradient(135deg, #e0f4f7 0%, #ffffff 100%); border: none; border-radius: 20px; box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06); padding: 1.75rem; transition: all 0.3s ease; position: relative; overflow: hidden; height: 100%; border-left: 4px solid #3b9bad;" 
                     onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 24px rgba(0, 0, 0, 0.1)';" 
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 16px rgba(0, 0, 0, 0.06)';">
                    <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, #3b9bad, #2d8599);"></div>
                    <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(59, 155, 173, 0.1); color: #3b9bad; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #64748b; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.5rem;">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                        </svg>
                        Balance Neto
                    </p>
                    <h3 style="font-size: 1.75rem; font-weight: 900; color: #3b9bad; margin: 0; text-shadow: 0 2px 4px rgba(59, 155, 173, 0.1);">
                        @Model.Balance.ToString("N2") €
                    </h3>
                </div>
            </div>

            <!-- Facturas Pendientes -->
            <div class="col-md-3">
                <div style="background: linear-gradient(135deg, #fffbeb 0%, #ffffff 100%); border: none; border-radius: 20px; box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06); padding: 1.75rem; transition: all 0.3s ease; position: relative; overflow: hidden; height: 100%; border-left: 4px solid #f59e0b;" 
                     onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 24px rgba(0, 0, 0, 0.1)';" 
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 16px rgba(0, 0, 0, 0.06)';">
                    <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, #f59e0b, #d97706);"></div>
                    <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(245, 158, 11, 0.1); color: #f59e0b; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                        </svg>
                    </div>
                    <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #64748b; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.5rem;">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        Facturas Pendientes
                    </p>
                    <h3 style="font-size: 1.75rem; font-weight: 900; color: #f59e0b; margin: 0; text-shadow: 0 2px 4px rgba(245, 158, 11, 0.1);">
                        @Model.FacturasPendientes
                    </h3>
                </div>
            </div>
        </div>

        <!-- Sección de Acciones -->
        <div style="background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); border: 1px solid #e5e7eb; border-radius: 20px; padding: 2rem; margin-bottom: 2rem; box-shadow: 0 4px 16px rgba(0, 0, 0, 0.05); position: relative; overflow: hidden;">
            <div style="position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #3b9bad, #10b981);"></div>
            
            <h5 style="font-weight: 800; color: #1f2937; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem; font-size: 1.25rem;">
                <svg width="24" height="24" fill="none" stroke="#3b9bad" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                Acciones Recomendadas
            </h5>

            @if (!Model.EstaConfigurado)
            {
                <!-- Alerta de Configuración -->
                <div class="mb-4">
                    <div style="background: linear-gradient(135deg, #dbeafe 0%, #eff6ff 100%); border: 2px solid #93c5fd; border-radius: 16px; padding: 1.5rem; display: flex; align-items: start; gap: 1rem; box-shadow: 0 2px 8px rgba(59, 130, 246, 0.1);">
                        <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(59, 130, 246, 0.15); color: #3b82f6; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div>
                            <h6 style="font-weight: 700; color: #1e40af; margin-bottom: 0.5rem; font-size: 1rem;">Configuración Inicial Incompleta</h6>
                            <p style="color: #1e3a8a; margin: 0; font-size: 0.9rem; line-height: 1.6;">
                                Para poder emitir facturas o calcular nóminas, primero debes configurar los datos maestros de tu empresa. Sigue estos pasos:
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Cards de Pasos de Configuración -->
                <div class="row g-4">
                    @if (!Model.TieneDepartamentos)
                    {
                        <div class="col-md-4">
                            <a asp-controller="Departamentos" asp-action="Index" class="text-decoration-none" style="display: block;">
                                <div style="background: white; border: 2px solid #e5e7eb; border-radius: 16px; padding: 2rem; text-align: center; transition: all 0.3s ease; height: 100%; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);"
                                     onmouseover="this.style.transform='translateY(-6px)'; this.style.boxShadow='0 8px 24px rgba(99, 102, 241, 0.15)'; this.style.borderColor='#6366f1';"
                                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0, 0, 0, 0.04)'; this.style.borderColor='#e5e7eb';">
                                    <div style="width: 72px; height: 72px; border-radius: 16px; background: linear-gradient(135deg, #eef2ff, #e0e7ff); color: #6366f1; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15);">
                                        <svg width="36" height="36" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                                        </svg>
                                    </div>
                                    <div style="background: linear-gradient(90deg, #6366f1, #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-size: 0.75rem; font-weight: 800; letter-spacing: 1px; margin-bottom: 0.75rem;">
                                        PASO 1
                                    </div>
                                    <h6 style="font-weight: 800; color: #1f2937; margin-bottom: 0.75rem; font-size: 1.1rem;">Crear Departamentos</h6>
                                    <p style="color: #6b7280; font-size: 0.9rem; margin: 0; line-height: 1.5;">Define la estructura organizativa de tu empresa.</p>
                                </div>
                            </a>
                        </div>
                    }

                    @if (!Model.TieneClientes)
                    {
                        <div class="col-md-4">
                            <a asp-controller="Facturacion" asp-action="Clientes" class="text-decoration-none" style="display: block;">
                                <div style="background: white; border: 2px solid #e5e7eb; border-radius: 16px; padding: 2rem; text-align: center; transition: all 0.3s ease; height: 100%; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);"
                                     onmouseover="this.style.transform='translateY(-6px)'; this.style.boxShadow='0 8px 24px rgba(16, 185, 129, 0.15)'; this.style.borderColor='#10b981';"
                                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0, 0, 0, 0.04)'; this.style.borderColor='#e5e7eb';">
                                    <div style="width: 72px; height: 72px; border-radius: 16px; background: linear-gradient(135deg, #ecfdf5, #d1fae5); color: #10b981; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.15);">
                                        <svg width="36" height="36" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                                        </svg>
                                    </div>
                                    <div style="background: linear-gradient(90deg, #10b981, #059669); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-size: 0.75rem; font-weight: 800; letter-spacing: 1px; margin-bottom: 0.75rem;">
                                        PASO 2
                                    </div>
                                    <h6 style="font-weight: 800; color: #1f2937; margin-bottom: 0.75rem; font-size: 1.1rem;">Añadir Clientes</h6>
                                    <p style="color: #6b7280; font-size: 0.9rem; margin: 0; line-height: 1.5;">Registra a quién vas a facturar tus servicios.</p>
                                </div>
                            </a>
                        </div>
                    }

                    @if (Model.TieneDepartamentos && !Model.TieneEmpleados)
                    {
                        <div class="col-md-4">
                            <a asp-controller="Empleados" asp-action="Create" class="text-decoration-none" style="display: block;">
                                <div style="background: white; border: 2px solid #e5e7eb; border-radius: 16px; padding: 2rem; text-align: center; transition: all 0.3s ease; height: 100%; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);"
                                     onmouseover="this.style.transform='translateY(-6px)'; this.style.boxShadow='0 8px 24px rgba(59, 155, 173, 0.15)'; this.style.borderColor='#3b9bad';"
                                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0, 0, 0, 0.04)'; this.style.borderColor='#e5e7eb';">
                                    <div style="width: 72px; height: 72px; border-radius: 16px; background: linear-gradient(135deg, #e0f4f7, #d1f0f5); color: #3b9bad; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; box-shadow: 0 4px 12px rgba(59, 155, 173, 0.15);">
                                        <svg width="36" height="36" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
                                        </svg>
                                    </div>
                                    <div style="background: linear-gradient(90deg, #3b9bad, #2d8599); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-size: 0.75rem; font-weight: 800; letter-spacing: 1px; margin-bottom: 0.75rem;">
                                        PASO 3
                                    </div>
                                    <h6 style="font-weight: 800; color: #1f2937; margin-bottom: 0.75rem; font-size: 1.1rem;">Alta de Empleados</h6>
                                    <p style="color: #6b7280; font-size: 0.9rem; margin: 0; line-height: 1.5;">Añade a tu plantilla para gestionar sus nóminas.</p>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- Acciones Principales -->
                <div class="row g-4">
                    <div class="col-md-6">
                        <a asp-controller="Facturacion" asp-action="NuevaFactura" class="text-decoration-none" style="display: block;">
                            <div style="background: linear-gradient(135deg, #ecfdf5 0%, #ffffff 100%); border: 2px solid #d1fae5; border-radius: 16px; padding: 2rem; transition: all 0.3s ease; height: 100%; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.08);"
                                 onmouseover="this.style.transform='translateY(-6px)'; this.style.boxShadow='0 10px 28px rgba(16, 185, 129, 0.2)'; this.style.borderColor='#10b981';"
                                 onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 12px rgba(16, 185, 129, 0.08)'; this.style.borderColor='#d1fae5';">
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width: 72px; height: 72px; border-radius: 16px; background: linear-gradient(135deg, #10b981, #059669); color: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 6px 20px rgba(16, 185, 129, 0.3);">
                                        <svg width="36" height="36" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                        </svg>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 style="font-weight: 800; color: #1f2937; margin-bottom: 0.5rem; font-size: 1.25rem;">Emitir Nueva Factura</h5>
                                        <p style="color: #6b7280; font-size: 0.95rem; margin: 0; line-height: 1.5;">Factura a tus clientes y genera apuntes automáticos.</p>
                                    </div>
                                    <div style="color: #10b981; font-size: 1.5rem;">
                                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
                                        </svg>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>

                    <div class="col-md-6">
                        <a asp-controller="Payroll" asp-action="Index" class="text-decoration-none" style="display: block;">
                            <div style="background: linear-gradient(135deg, #e0f4f7 0%, #ffffff 100%); border: 2px solid #b3e5ec; border-radius: 16px; padding: 2rem; transition: all 0.3s ease; height: 100%; box-shadow: 0 4px 12px rgba(59, 155, 173, 0.08);"
                                 onmouseover="this.style.transform='translateY(-6px)'; this.style.boxShadow='0 10px 28px rgba(59, 155, 173, 0.2)'; this.style.borderColor='#3b9bad';"
