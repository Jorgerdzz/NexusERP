@model NexusERP.ViewModels.HomeDashboardViewModel
@{
    ViewData["Title"] = "Panel de Control";
    ViewData["ActiveMenu"] = "home";
}

<main class="bg-light pb-5 min-vh-100">
    <div class="container-fluid px-4 pt-4 dashboard-container">

        <!-- Header de Bienvenida -->
        <div class="mb-5 d-flex flex-column gap-1">
            <h1 class="h3 fw-bold text-dark mb-0">¡Hola, @Model.NombreUsuario!</h1>
            <p class="text-muted mb-0">Resumen financiero general del año @DateTime.Now.Year.</p>
        </div>

        <!-- KPIs Financieros -->
        <div class="row g-4 mb-5">
            <!-- Ingresos Anuales -->
            <div class="col-md-3">
                <div class="card dashboard-card h-100">
                    <div class="card-body d-flex flex-column justify-content-between p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-muted fw-medium text-xs tracking-wide text-uppercase">Ingresos Anuales</span>
                            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" class="text-muted opacity-75">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="fw-bold text-dark mb-0">@Model.TotalFacturadoAnual.ToString("N2") <span class="fs-6 text-muted fw-normal">€</span></h3>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Gasto Salarial -->
            <div class="col-md-3">
                <div class="card dashboard-card h-100">
                    <div class="card-body d-flex flex-column justify-content-between p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-muted fw-medium text-xs tracking-wide text-uppercase">Gasto Salarial</span>
                            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" class="text-muted opacity-75">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="fw-bold text-dark mb-0">@Model.TotalGastoSalarial.ToString("N2") <span class="fs-6 text-muted fw-normal">€</span></h3>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Balance Neto -->
            <div class="col-md-3">
                <div class="card dashboard-card h-100">
                    <div class="card-body d-flex flex-column justify-content-between p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-muted fw-medium text-xs tracking-wide text-uppercase">Balance Neto</span>
                            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" class="text-muted opacity-75">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div>
                            @{
                                string colorBalance = Model.Balance >= 0 ? "text-dark" : "text-danger";
                            }
                            <h3 class="fw-bold @colorBalance mb-0">@Model.Balance.ToString("N2") <span class="fs-6 text-muted fw-normal">€</span></h3>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Facturas Pendientes -->
            <div class="col-md-3">
                <div class="card dashboard-card h-100">
                    <div class="card-body d-flex flex-column justify-content-between p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-muted fw-medium text-xs tracking-wide text-uppercase">Facturas Pendientes</span>
                            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" class="text-muted opacity-75">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="fw-bold text-dark mb-0">@Model.FacturasPendientes</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sección de Acciones -->
        <div class="mb-2">
            <h4 class="h5 fw-bold text-dark mb-4">Acciones Recomendadas</h4>

            @if (!Model.EstaConfigurado)
            {
                <!-- Alerta de Configuración -->
                <div class="alert alert-primary bg-primary bg-opacity-10 border border-primary border-opacity-25 d-flex gap-3 align-items-start rounded-3 p-3 mb-4">
                    <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" class="mt-1 flex-shrink-0">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div>
                        <h6 class="fw-bold mb-1">Configuración Inicial Incompleta</h6>
                        <p class="mb-0 text-dark text-opacity-75 small">Para poder emitir facturas o calcular nóminas, primero debes configurar los datos maestros de tu empresa.</p>
                    </div>
                </div>

                <!-- Cards de Pasos de Configuración -->
                <div class="row g-4">
                    @if (!Model.TieneDepartamentos)
                    {
                        <div class="col-md-4">
                            <a asp-controller="Departamentos" asp-action="Index" class="text-decoration-none">
                                <div class="card dashboard-card transition-hover h-100 p-4">
                                    <div class="mb-3">
                                        <span class="badge border border-secondary text-secondary bg-light px-2 py-1 tracking-wide">PASO 1</span>
                                    </div>
                                    <h6 class="fw-bold text-dark mb-2">Crear Departamentos</h6>
                                    <p class="text-muted small mb-0">Define la estructura organizativa de tu empresa.</p>
                                </div>
                            </a>
                        </div>
                    }

                    @if (!Model.TieneClientes)
                    {
                        <div class="col-md-4">
                            <a asp-controller="Facturacion" asp-action="Clientes" class="text-decoration-none">
                                <div class="card dashboard-card transition-hover h-100 p-4">
                                    <div class="mb-3">
                                        <span class="badge border border-secondary text-secondary bg-light px-2 py-1 tracking-wide">PASO 2</span>
                                    </div>
                                    <h6 class="fw-bold text-dark mb-2">Añadir Clientes</h6>
                                    <p class="text-muted small mb-0">Registra a quién vas a facturar tus servicios.</p>
                                </div>
                            </a>
                        </div>
                    }

                    @if (Model.TieneDepartamentos && !Model.TieneEmpleados)
                    {
                        <div class="col-md-4">
                            <a asp-controller="Empleados" asp-action="Create" class="text-decoration-none">
                                <div class="card dashboard-card transition-hover h-100 p-4">
                                    <div class="mb-3">
                                        <span class="badge border border-secondary text-secondary bg-light px-2 py-1 tracking-wide">PASO 3</span>
                                    </div>
                                    <h6 class="fw-bold text-dark mb-2">Alta de Empleados</h6>
                                    <p class="text-muted small mb-0">Añade a tu plantilla para gestionar sus nóminas.</p>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- Acciones Principales -->
                <div class="row g-4">
                    <div class="col-md-6">
                        <a asp-controller="Facturacion" asp-action="NuevaFactura" class="text-decoration-none">
                            <div class="card dashboard-card transition-hover p-4 d-flex flex-row align-items-center gap-4">
                                <div class="p-3 bg-light rounded-3 text-dark border">
                                    <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                    </svg>
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="fw-bold text-dark mb-1">Emitir Nueva Factura</h6>
                                    <p class="text-muted small mb-0">Factura a tus clientes y genera apuntes automáticos.</p>
                                </div>
                                <div class="text-muted">
                                    <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </div>
                            </div>
                        </a>
                    </div>

                    <div class="col-md-6">
                        <a asp-controller="Payroll" asp-action="Index" class="text-decoration-none">
                            <div class="card dashboard-card transition-hover p-4 d-flex flex-row align-items-center gap-4">
                                <div class="p-3 bg-light rounded-3 text-dark border">
                                    <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                                    </svg>
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="fw-bold text-dark mb-1">Calcular Nóminas</h6>
                                    <p class="text-muted small mb-0">Gestiona los recibos de salarios de este mes.</p>
                                </div>
                                <div class="text-muted">
                                    <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</main>

<style>
    .dashboard-container {
        animation: fadeIn 0.4s ease-out forwards;
    }

    .dashboard-card {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;    /* Muted clear border common in shadcn */
        border-radius: 0.5rem;        /* rounded-md equivalent */
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); /* Minimalist shadow */
    }

    .tracking-wide {
        letter-spacing: 0.05em;
    }
    
    .text-xs {
        font-size: 0.75rem;
    }

    .transition-hover {
        transition: all 0.2s ease-in-out;
    }

    .transition-hover:hover {
        border-color: #cbd5e1;        /* Slightly darker border on hover */
        background-color: #f8fafc;    /* Slight light-gray bg */
        cursor: pointer;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
