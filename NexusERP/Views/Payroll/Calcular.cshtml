@model CalcularNominaViewModel
@{
    ViewData["Title"] = "Cálculo de Nómina";
    string periodoLiquidacion = $"{Model.FechaInicio.ToString("dd/MM/yyyy")} al {Model.FechaFin.ToString("dd/MM/yyyy")}";
}


<main class="bg-light pb-5 min-vh-100">
    <div class="container-fluid px-4 pt-4">

        <!-- BOTÓN VOLVER -->
        <div class="mb-3">
            <a asp-controller="Payroll" asp-action="Index" class="btn btn-volver d-inline-flex align-items-center gap-2">
                <svg style="width: 16px; height: 16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                <span>Volver al gestor</span>
            </a>
        </div>

        <!-- CABECERA: DATOS DEL EMPLEADO -->
        <div class="card employee-header-card">
            <div class="card-body p-4 p-md-5">
                <div class="row align-items-center g-4">
                    <div class="col-md-7 d-flex align-items-center gap-4">
                        <div class="avatar-circle">
                            @Model.EmpleadoIniciales
                        </div>
                        <div class="flex-grow-1">
                            <h4 class="fw-bold text-dark mb-2">@Model.EmpleadoNombre</h4>
                            <p class="text-muted mb-3 fs-6">
                                <span class="fw-medium">@Model.DepartamentoNombre</span>
                                <span class="mx-2">•</span>
                                IRPF: <strong class="text-dark">@Model.PorcentajeIRPF%</strong>
                            </p>
                            <div class="info-badge">
                                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                </svg>
                                <span>Período: @periodoLiquidacion</span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-5 text-md-end">
                        <span class="text-muted d-block mb-2 text-uppercase fw-bold small">Salario Bruto Anual</span>
                        <h3 class="fw-bold text-dark mb-3">@Model.SalarioBrutoAnual.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) €</h3>

                        <div class="d-inline-flex align-items-center gap-2 bg-success-light px-3 py-2 rounded">
                            <svg style="width: 16px; height: 16px;" class="text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <span class="text-success small fw-medium">
                                Mensual sugerido (14 pagas): <strong id="salarioSugerido">@Model.SalarioMensualSugerido.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)</strong> €
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- FORMULARIO DE NÓMINA -->
        <div class="card nomina-form-card">
            <div class="form-header">
                <h2 class="text-center fw-bold text-primary-custom mb-2">Cálculo de Nómina Mensual</h2>
                <p class="text-center text-muted mb-0">Complete los conceptos retributivos para generar la nómina</p>
            </div>

            <div class="card-body p-4 p-lg-5">
                <form id="formNomina" asp-action="GuardarNomina" method="post">

                    <!-- DATOS OCULTOS -->
                    <input type="hidden" asp-for="EmpleadoId" />
                    <input type="hidden" asp-for="Mes" />
                    <input type="hidden" asp-for="Anio" />
                    <input type="hidden" asp-for="PorcentajeIRPF" id="porcentajeIrpfAplicado" />
                    <input type="hidden" asp-for="FechaInicio" />
                    <input type="hidden" asp-for="FechaFin" />

                    <!-- I. DEVENGOS -->
                    <div class="section-title">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <span>I. Devengos</span>
                    </div>

                    <p class="section-description">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="me-2">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        Introduzca los importes brutos correspondientes al período de liquidación. Puede añadir complementos salariales adicionales.
                    </p>

                    <!-- Salario Base (Fijo y destacado) -->
                    <h5 class="subsection-title">
                        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        Salario Base
                    </h5>

                    <div class="concepto-fijo-row">
                        <div class="row align-items-center">
                            <div class="col-md-6 mb-2 mb-md-0">
                                <span class="concepto-label">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                    Salario Base Mensual
                                </span>
                            </div>
                            <div class="col-md-6">
                                <div class="input-group">
                                    <input type="number" step="0.01" asp-for="SalarioBase" class="form-control concepto-input input-devengo" data-tributa-irpf="true" id="SalarioBase" readonly>
                                    <span class="input-group-text bg-light border-0">€</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- I.I. Percepciones Salariales (Dinámicas) -->
                    <h5 class="subsection-title mt-4">
                        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                        </svg>
                        Complementos Salariales
                    </h5>

                    <div id="conceptosSalarialesContainer">
                        <!-- Los conceptos dinámicos se añadirán aquí -->
                    </div>

                    <button type="button" class="btn btn-add-concepto" onclick="addConceptoSalarial()">
                        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="me-2">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                        </svg>
                        Añadir Complemento Salarial
                    </button>

                    <!-- I.II. Percepciones No Salariales (Dinámicas) -->
                    <h5 class="subsection-title mt-4">
                        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        Percepciones No Salariales
                    </h5>

                    <div id="conceptosNoSalarialesContainer">
                        <!-- Los conceptos dinámicos se añadirán aquí -->
                    </div>

                    <button type="button" class="btn btn-add-concepto" onclick="addConceptoNoSalarial()">
                        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="me-2">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                        </svg>
                        Añadir Concepto No Salarial
                    </button>

                    <!-- TOTAL DEVENGADO -->
                    <div class="total-box">
                        <div class="row align-items-center">
                            <div class="col-md-6 mb-2 mb-md-0">
                                <span class="total-label">Total Devengado (Salario Bruto)</span>
                            </div>
                            <div class="col-md-6">
                                <div class="input-group">
                                    <input type="text" id="total_devengado" name="TotalDevengado" class="form-control total-amount text-end border-0 bg-transparent shadow-none" readonly>
                                    <span class="input-group-text bg-transparent border-0 total-amount">€</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- II. DEDUCCIONES -->
                    <div class="section-title mt-5">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                        </svg>
                        <span>II. Deducciones (Trabajador)</span>
                    </div>

                    <div class="table-responsive mb-4">
                        <table class="table table-nomina-calc w-100 mb-0">
                            <thead>
                                <tr>
                                    <th>Concepto</th>
                                    <th class="text-center">Base (€)</th>
                                    <th class="text-center">Tipo (%)</th>
                                    <th class="text-end">Importe (€)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="fw-medium text-dark">Contingencias comunes</td>
                                    <td><input type="text" id="base_cc" name="BaseCotizacion_CC" class="form-control text-center bg-light border-0" readonly></td>
                                    <td><input type="text" id="tipo_cc" value="4.70" class="form-control text-center bg-light border-0 text-muted" readonly></td>
                                    <td><input type="text" id="importe_cc" name="SS_ContingenciasComunes" class="form-control text-end fw-bold" readonly></td>
                                </tr>
                                <tr>
                                    <td class="fw-medium text-dark">M.E.I</td>
                                    <td><input type="text" id="base_mei" class="form-control text-center bg-light border-0" readonly></td>
                                    <td><input type="text" id="tipo_mei" value="0.12" class="form-control text-center bg-light border-0 text-muted" readonly></td>
                                    <td><input type="text" id="importe_mei" name="SS_MEI" class="form-control text-end fw-bold" readonly></td>
                                </tr>
                                <tr>
                                    <td class="fw-medium text-dark">Desempleo</td>
                                    <td><input type="text" id="base_desempleo" name="BaseCotizacion_CP" class="form-control text-center bg-light border-0" readonly></td>
                                    <td><input type="text" id="tipo_desempleo" value="1.55" class="form-control text-center bg-light border-0 text-muted" readonly></td>
                                    <td><input type="text" id="importe_desempleo" name="SS_Desempleo" class="form-control text-end fw-bold" readonly></td>
                                </tr>
                                <tr>
                                    <td class="fw-medium text-dark">Formación profesional</td>
                                    <td><input type="text" id="base_fp" class="form-control text-center bg-light border-0" readonly></td>
                                    <td><input type="text" id="tipo_fp" value="0.10" class="form-control text-center bg-light border-0 text-muted" readonly></td>
                                    <td><input type="text" id="importe_fp" name="SS_Formacion" class="form-control text-end fw-bold" readonly></td>
                                </tr>
                                <tr class="highlight-irpf">
                                    <td class="fw-bold text-primary-custom">I.R.P.F.</td>
                                    <td><input type="text" id="base_irpf" name="BaseIRPF" class="form-control text-center bg-transparent border-0 fw-bold" readonly></td>
                                    <td><input type="text" id="tipo_irpf_view" value="@Model.PorcentajeIRPF" class="form-control text-center bg-transparent border-0 fw-bold text-primary-custom" readonly></td>
                                    <td><input type="text" id="importe_irpf" name="RetencionIRPF" class="form-control text-end fw-bold text-danger bg-transparent border-0" readonly></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="row align-items-center mb-3">
                        <div class="col-md-8 text-end">
                            <span class="text-muted fw-medium">Total Aportaciones a la Seguridad Social</span>
                        </div>
                        <div class="col-md-4">
                            <div class="input-group">
                                <input type="text" id="total_aportaciones" class="form-control text-end bg-light border-0 fw-medium shadow-none" readonly>
                                <span class="input-group-text bg-light border-0 text-muted">€</span>
                            </div>
                        </div>
                    </div>

                    <div class="row align-items-center mb-5">
                        <div class="col-md-8 text-end">
                            <strong class="text-dark fs-5">Total Deducciones Trabajador</strong>
                        </div>
                        <div class="col-md-4">
                            <div class="input-group">
                                <input type="text" id="total_deducciones" name="TotalDeducciones" class="form-control text-end fw-bold text-danger bg-light border-0 shadow-none fs-5" readonly>
                                <span class="input-group-text bg-light border-0 fw-bold text-danger fs-5">€</span>
                            </div>
                        </div>
                    </div>

                    <!-- LÍQUIDO A PERCIBIR -->
                    <div class="liquido-box">
                        <div class="row align-items-center">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <div class="liquido-label">Líquido a Percibir</div>
                                <p class="liquido-subtitle mb-0">Importe neto a cobrar</p>
                            </div>
                            <div class="col-md-6 text-md-end">
                                <div class="d-flex align-items-center justify-content-md-end gap-2">
                                    <input type="text" id="liquido_percibir" name="LiquidoAPercibir" class="liquido-amount border-0 bg-transparent text-end" readonly value="0,00" style="width: auto; max-width: 300px;">
                                    <span class="liquido-amount">€</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- III. COSTES DE EMPRESA -->
                    <div class="section-title mt-5">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                        </svg>
                        <span>III. Costes de Empresa</span>
                    </div>

                    <div class="table-responsive mb-4">
                        <table class="table table-nomina-calc w-100 mb-0">
                            <thead>
                                <tr>
                                    <th>Concepto</th>
                                    <th class="text-center">Base (€)</th>
                                    <th class="text-center">Tipo (%)</th>
                                    <th class="text-end">Importe (€)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="fw-medium text-dark">Contingencias Comunes</td>
                                    <td><input type="text" id="base_empresa_cc" class="form-control text-center bg-light border-0" readonly></td>
                                    <td><input type="text" value="23.60" class="form-control text-center bg-light border-0 text-muted" readonly></td>
                                    <td><input type="text" id="importe_empresa_cc" name="SS_Empresa_ContingenciasComunes" class="form-control text-end fw-bold" readonly></td>
                                </tr>
                                <tr>
                                    <td class="fw-medium text-dark">Horas Extraordinarias</td>
                                    <td><input type="text" id="base_empresa_he" class="form-control text-center bg-light border-0" readonly></td>
                                    <td><input type="text" value="23.60" class="form-control text-center bg-light border-0 text-muted" readonly></td>
                                    <td><input type="text" id="importe_empresa_he" name="SS_Empresa_HorasExtras" class="form-control text-end fw-bold" readonly></td>
                                </tr>
                                <tr>
                                    <td class="fw-medium text-dark">AT y EP</td>
                                    <td><input type="text" id="base_empresa_at" class="form-control text-center bg-light border-0" readonly></td>
                                    <td><input type="text" value="1.50" class="form-control text-center bg-light border-0 text-muted" readonly></td>
                                    <td><input type="text" id="importe_empresa_at" name="SS_Empresa_AccidentesTrabajo" class="form-control text-end fw-bold" readonly></td>
                                </tr>
                                <tr>
                                    <td class="fw-medium text-dark">Desempleo</td>
                                    <td><input type="text" id="base_empresa_desempleo" class="form-control text-center bg-light border-0" readonly></td>
                                    <td><input type="text" value="5.50" class="form-control text-center bg-light border-0 text-muted" readonly></td>
                                    <td><input type="text" id="importe_empresa_desempleo" name="SS_Empresa_Desempleo" class="form-control text-end fw-bold" readonly></td>
                                </tr>
                                <tr>
                                    <td class="fw-medium text-dark">Formación Profesional</td>
                                    <td><input type="text" id="base_empresa_formacion" class="form-control text-center bg-light border-0" readonly></td>
                                    <td><input type="text" value="0.60" class="form-control text-center bg-light border-0 text-muted" readonly></td>
                                    <td><input type="text" id="importe_empresa_formacion" name="SS_Empresa_Formacion" class="form-control text-end fw-bold" readonly></td>
                                </tr>
                                <tr>
                                    <td class="fw-medium text-dark">F.O.G.A.S.A.</td>
                                    <td><input type="text" id="base_empresa_fogasa" class="form-control text-center bg-light border-0" readonly></td>
                                    <td><input type="text" value="0.20" class="form-control text-center bg-light border-0 text-muted" readonly></td>
                                    <td><input type="text" id="importe_empresa_fogasa" name="SS_Empresa_Fogasa" class="form-control text-end fw-bold" readonly></td>
                                </tr>
                                <tr>
                                    <td class="fw-medium text-dark">M.E.I.</td>
                                    <td><input type="text" id="base_empresa_mei" class="form-control text-center bg-light border-0" readonly></td>
                                    <td><input type="text" value="0.58" class="form-control text-center bg-light border-0 text-muted" readonly></td>
                                    <td><input type="text" id="importe_empresa_mei" name="SS_Empresa_MEI" class="form-control text-end fw-bold" readonly></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- TOTAL COSTE EMPRESA -->
                    <div class="total-box">
                        <div class="row align-items-center">
                            <div class="col-md-6 mb-2 mb-md-0">
                                <div class="total-label mb-1">Coste Real para la Empresa</div>
                                <div class="text-muted fw-normal small">(Bruto + Seguridad Social Empresa)</div>
                            </div>
                            <div class="col-md-6">
                                <div class="input-group">
                                    <input type="text" id="coste_total_empresa" name="CosteTotalEmpresa" class="form-control total-amount text-end border-0 bg-transparent shadow-none" readonly value="0,00">
                                    <span class="input-group-text bg-transparent border-0 total-amount">€</span>
                                </div>
                                <input type="hidden" id="total_empresa_ss_hidden" name="SS_Empresa_Total">
                            </div>
                        </div>
                    </div>

                    <!-- BOTÓN DE ENVÍO -->
                    <div class="d-flex justify-content-end pt-5 mt-4 border-top">
                        <button type="submit" class="btn btn-submit-nomina">
                            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="me-2">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            Generar y Guardar Nómina
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script src="~/js/calculo-nomina.js" asp-append-version="true"></script>
    <script>
        // Añadir efecto de loading al botón de submit
        document.getElementById('formNomina').addEventListener('submit', function() {
            const btn = document.querySelector('.btn-submit-nomina');
            btn.classList.add('loading');
        });
    </script>
}