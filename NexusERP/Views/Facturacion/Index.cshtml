@model NexusERP.ViewModels.DashboardFacturacionViewModel
@{
    ViewData["Title"] = "Panel de Facturación";
    ViewData["ActiveMenu"] = "facturacion";
}

<main class="bg-light pb-5 min-vh-100">
    <div class="container-fluid px-4 pt-4">

        <!-- Header -->
        <div class="mb-4">
            <h1 class="h4 fw-bold text-dark mb-1">Panel de Facturación</h1>
            <p class="text-muted small">Resumen financiero, facturas y cartera de clientes</p>
        </div>

        <!-- Cards de Acción Principales -->
        <div class="row g-4 mb-5">
            <div class="col-md-6">
                <div class="action-card p-4">
                    <a asp-controller="Facturacion" asp-action="NuevaFactura" class="text-decoration-none">
                        <div class="d-flex align-items-center">
                            <div class="icon-container icon-invoice me-4 shadow-sm">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                    <polyline points="14 2 14 8 20 8"></polyline>
                                    <line x1="16" y1="13" x2="8" y2="13"></line>
                                    <line x1="16" y1="17" x2="8" y2="17"></line>
                                    <polyline points="10 9 9 9 8 9"></polyline>
                                </svg>
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-1">Emitir Nueva Factura</h5>
                                <p class="text-muted small mb-0">Crea una factura con desglose de IVA y contabilízala automáticamente.</p>
                            </div>
                            <div class="ms-auto text-muted">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="9 18 15 12 9 6"></polyline>
                                </svg>
                            </div>
                        </div>
                    </a>
                </div>
            </div>

            <div class="col-md-6">
                <div class="action-card p-4">
                    <a asp-controller="Clientes" asp-action="Index" class="text-decoration-none">
                        <div class="d-flex align-items-center">
                            <div class="icon-container icon-clients me-4 shadow-sm">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="9" cy="7" r="4"></circle>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                </svg>
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-1">Directorio de Clientes</h5>
                                <p class="text-muted small mb-0">Gestiona la información fiscal y el estado de tu cartera de clientes.</p>
                            </div>
                            <div class="ms-auto text-muted">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="9 18 15 12 9 6"></polyline>
                                </svg>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <!-- KPI Cards con Colores -->
        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="card card-kpi card-kpi-primary h-100 p-4 kpi-wrapper" style="animation-delay: 0.1s;">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <p class="text-muted small fw-semibold text-uppercase mb-0">Facturado (Mes)</p>
                        <div class="icon-kpi" style="background: linear-gradient(135deg, #e0f4f7, #ffffff);">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--secondary-color, #3b9bad)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="12" y1="1" x2="12" y2="23"></line>
                                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                            </svg>
                        </div>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0 text-dark-heading">
                            @Model.FacturadoEsteMes.ToString("N2") <span class="fs-6 fw-normal text-muted">€</span>
                        </h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card card-kpi card-kpi-warning h-100 p-4 kpi-wrapper" style="animation-delay: 0.2s;">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <p class="text-muted small fw-semibold text-uppercase mb-0">Pdte. de Cobro</p>
                        <div class="icon-kpi" style="background: linear-gradient(135deg, #fffbeb, #ffffff);">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                        </div>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0" style="color: #f59e0b;">
                            @Model.PendienteDeCobro.ToString("N2") <span class="fs-6 fw-normal text-muted">€</span>
                        </h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card card-kpi card-kpi-success h-100 p-4 kpi-wrapper" style="animation-delay: 0.3s;">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <p class="text-muted small fw-semibold text-uppercase mb-0">Facturas Emitidas</p>
                        <div class="icon-kpi" style="background: linear-gradient(135deg, #e8f8f0, #ffffff);">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--success-color, #10b981)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
                                <polyline points="13 2 13 9 20 9"></polyline>
                            </svg>
                        </div>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0 text-dark-heading">
                            @Model.TotalFacturas <span class="fs-6 fw-normal text-muted">docs</span>
                        </h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card card-kpi card-kpi-purple h-100 p-4 kpi-wrapper" style="animation-delay: 0.4s;">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <p class="text-muted small fw-semibold text-uppercase mb-0">Clientes Activos</p>
                        <div class="icon-kpi" style="background: linear-gradient(135deg, #f3e8ff, #ffffff);">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9333ea" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                <circle cx="9" cy="7" r="4"></circle>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                            </svg>
                        </div>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0 text-dark-heading">
                            @Model.TotalClientes <span class="fs-6 fw-normal text-muted">activos</span>
                        </h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabla de Facturas -->
        <div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold text-dark mb-0">Últimas Facturas Emitidas</h5>
            </div>
            
            <div class="table-responsive">
                <table class="table table-minimalist w-100 mb-0">
                    <thead>
                        <tr>
                            <th>Nº Factura</th>
                            <th>Cliente</th>
                            <th>Fecha Emisión</th>
                            <th class="text-end">Importe Total</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var factura in Model.UltimasFacturas)
                        {
                            <tr>
                                <td class="fw-bold text-dark">
                                    @factura.NumeroFactura
                                </td>
                                <td>
                                    <span class="fw-medium text-dark d-block">@factura.Cliente.RazonSocial</span>
                                </td>
                                <td>
                                    @factura.FechaEmision.ToString("dd MMM yyyy")
                                </td>
                                <td class="text-end fw-bold text-dark">
                                    @factura.TotalFactura.ToString("N2") €
                                </td>
                                <td class="text-center">
                                    @if (factura.Estado == "Pendiente")
                                    {
                                        <span class="badge-status status-pendiente">Pendiente</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status status-pagada">Pagada</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex align-items-center justify-content-center gap-2">
                                        <a asp-action="Details" asp-route-id="@factura.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3 fw-medium" title="Ver Factura">
                                            <i class="far fa-eye me-1"></i> Ver
                                        </a>

                                        @if (factura.Estado == "Pendiente")
                                        {
                                            <form asp-action="RegistrarCobro" asp-controller="Facturacion" method="post" class="m-0">
                                                <input type="hidden" name="idFactura" value="@factura.Id" />
                                                <button type="submit" class="btn btn-sm text-success bg-success-light border border-success border-opacity-25 rounded-pill px-3 fw-bold shadow-sm">
                                                    <i class="fas fa-hand-holding-usd me-1"></i> Cobrar
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }

                        @if (!Model.UltimasFacturas.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mb-3">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                        <polyline points="14 2 14 8 20 8"></polyline>
                                        <line x1="16" y1="13" x2="8" y2="13"></line>
                                        <line x1="16" y1="17" x2="8" y2="17"></line>
                                        <polyline points="10 9 9 9 8 9"></polyline>
                                    </svg>
                                    <h6 class="fw-bold text-dark mb-1">Sin facturas recientes</h6>
                                    <p class="text-muted small mb-0">Aún no se ha emitido ninguna factura en el sistema.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</main>