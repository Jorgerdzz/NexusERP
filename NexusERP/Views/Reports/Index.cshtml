@model NexusERP.ViewModels.ReportsViewModel
@{
    ViewData["Title"] = "Análisis e Informes";
    ViewData["ActiveMenu"] = "reports";

    // Serializamos las listas a JSON
    var ingresosJson = System.Text.Json.JsonSerializer.Serialize(Model.IngresosMensuales);
    var gastosJson = System.Text.Json.JsonSerializer.Serialize(Model.GastosMensuales);
    var labelsDeptJson = System.Text.Json.JsonSerializer.Serialize(Model.DepartamentosNombres);
    var datosDeptJson = System.Text.Json.JsonSerializer.Serialize(Model.GastosPorDepartamento);
}

<main class="bg-light pb-5 min-vh-100">
    <div id="chartDataContainer"
         class="container-fluid px-4 pt-4 reports-container"
         data-ingresos="@ingresosJson"
         data-gastos="@gastosJson"
         data-labels-dept="@labelsDeptJson"
         data-datos-dept="@datosDeptJson">

        <div class="reports-header">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <h1 class="page-title h3 mb-2">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="me-2" style="display: inline-block; vertical-align: middle;">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                        </svg>
                        Análisis e Informes (@Model.AnioActual)
                    </h1>
                    <p class="text-muted mb-0">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="me-1">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        Rendimiento financiero y distribución de costes estructurales.
                    </p>
                </div>

                <form method="get" class="d-flex gap-2">
                    <select name="anio" class="form-select year-selector" onchange="this.form.submit()">
                        @for (int i = DateTime.Now.Year; i >= DateTime.Now.Year - 3; i--)
                        {
                            if (i == Model.AnioActual)
                            {
                                <option value="@i" selected>Año @i</option>
                            }
                            else
                            {
                                <option value="@i">Año @i</option>
                            }
                        }
                    </select>
                </form>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="kpi-card success">
                    <div class="kpi-icon">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                        </svg>
                    </div>
                    <div class="kpi-label">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        Total Ingresos Anual
                    </div>
                    <h3 class="kpi-value">@Model.TotalIngresosAnual.ToString("N2") €</h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="kpi-card danger">
                    <div class="kpi-icon">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"></path>
                        </svg>
                    </div>
                    <div class="kpi-label">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path>
                        </svg>
                        Total Costes Salariales
                    </div>
                    <h3 class="kpi-value">@Model.TotalGastosAnual.ToString("N2") €</h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="kpi-card primary">
                    <div class="kpi-icon">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <div class="kpi-label">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        Beneficio / Margen Bruto
                    </div>
                    <h3 class="kpi-value">@Model.BeneficioAnual.ToString("N2") €</h3>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="chart-card">
                    <div class="chart-header">
                        <h6>
                            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path>
                            </svg>
                            Evolución: Ingresos vs Costes Salariales
                        </h6>
                    </div>
                    <div class="chart-body" style="height: 500px;">
                        <canvas id="evolucionChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="chart-card">
                    <div class="chart-header">
                        <h6>
                            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path>
                            </svg>
                            Coste por Departamento
                        </h6>
                    </div>
                    <div class="chart-body d-flex justify-content-center align-items-center">
                        <canvas id="deptChart" height="250"></canvas>
                    </div>
                </div>
            </div>
        </div>

    </div>
</main>

@section Scripts {
    <script src="~/js/reports-charts.js" asp-append-version="true"></script>
}