@model IndexDepartamentosViewModel

@{
    ViewData["Title"] = "Departamentos y Equipo";
}

<div class="container-fluid py-4 min-vh-100 bg-light">

    @if(Model.TotalDepartamentos != 0)
    {
        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-end mb-4 kpi-wrapper">
            <div>
                <h2 class="fw-bold mb-1 text-dark-heading">Departamentos y Equipo</h2>
                <p class="text-muted mb-0 small">Gestiona las áreas, presupuestos y personal de tu empresa.</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-controller="Empleados" class="btn btn-outline-secondary d-flex align-items-center gap-2 px-3 shadow-sm rounded-3">
                    <svg style="width: 18px; height: 18px" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Ver plantilla
                </a>
                <button class="btn btn-primary d-flex align-items-center gap-2 px-3 shadow-sm rounded-3" style="background-color: var(--secondary-color); border-color: var(--secondary-color);" data-bs-toggle="modal" data-bs-target="#modal-add-department">
                    <svg style="width: 18px; height: 18px" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                    Nuevo Departamento
                </button>
            </div>
        </div>

        <!-- CARDS GLOBALES (KPIs) -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4 mb-5">

            <!-- Departamentos -->
            <div class="col">
                <div class="card card-kpi card-kpi-1 h-100 p-4 kpi-wrapper">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <p class="text-muted small fw-semibold text-uppercase mb-0">Total Áreas</p>
                        <div class="icon-kpi" style="background: linear-gradient(135deg, #e0f4f7, #ffffff);">
                            <svg width="24" height="24" fill="none" stroke="var(--secondary-color)" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                            </svg>
                        </div>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0 text-dark-heading">@Model.TotalDepartamentos</h3>
                        <p class="text-muted small mt-1 mb-0">Departamentos activos</p>
                    </div>
                </div>
            </div>

            <!-- Plantilla Total -->
            <div class="col">
                <div class="card card-kpi card-kpi-2 h-100 p-4 kpi-wrapper">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <p class="text-muted small fw-semibold text-uppercase mb-0">Plantilla Global</p>
                        <div class="icon-kpi" style="background: linear-gradient(135deg, #e8f8f0, #ffffff);">
                            <svg width="24" height="24" fill="none" stroke="var(--success-color)" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0z"></path>
                            </svg>
                        </div>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0 text-dark-heading">@Model.TotalEmpleadosGlobal</h3>
                        <p class="text-muted small mt-1 mb-0">Empleados en nómina</p>
                    </div>
                </div>
            </div>

            <!-- Presupuesto Total Anual -->
            <div class="col">
                <div class="card card-kpi card-kpi-3 h-100 p-4 kpi-wrapper">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <p class="text-muted small fw-semibold text-uppercase mb-0">Presupuesto Anual</p>
                        <div class="icon-kpi" style="background: linear-gradient(135deg, #fff8e6, #ffffff);">
                            <svg width="24" height="24" fill="none" stroke="#f59e0b" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0" style="color: #d97706;">@Model.PresupuestoTotalGlobalAnual.ToString("N0") <span class="fs-6 fw-normal">€</span></h3>
                        <p class="text-muted small mt-1 mb-0">≈ @Model.PresupuestoTotalGlobalMensual.ToString("N0") € / mes</p>
                    </div>
                </div>
            </div>

            <!-- Salario Promedio -->
            <div class="col">
                <div class="card card-kpi card-kpi-4 h-100 p-4 kpi-wrapper">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <p class="text-muted small fw-semibold text-uppercase mb-0">Salario Anual Promedio</p>
                        <div class="icon-kpi" style="background: linear-gradient(135deg, #fef2f2, #ffffff);">
                            <svg width="24" height="24" fill="none" stroke="#ef4444" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                            </svg>
                        </div>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0" style="color: #ef4444;">@Model.SalarioPromedioGlobalAnual.ToString("N0") <span class="fs-6 fw-normal">€</span></h3>
                        <p class="text-muted small mt-1 mb-0">≈ @Model.SalarioPromedioGlobalMensual.ToString("N0") € / mes</p>
                    </div>
                </div>
            </div>

        </div>

        <h5 class="fw-bold text-dark-heading mb-3 px-1">Detalle por Departamento</h5>

        <!-- CARDS DE DEPARTAMENTOS -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4 mb-4">
            @if (Model.Departamentos.Count != 0)
            {
                var delayMulti = 1;
                @foreach (DepartamentoCardViewModel dept in Model.Departamentos)
                {
                    <div class="col dept-wrapper" style="animation-delay: @(delayMulti * 0.1)s;">
                        <div class="card custom-card card-custom h-100 p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3 border-bottom pb-3">
                                <h6 class="fw-bold mb-0 text-content align-self-center">@dept.Nombre</h6>
                                <div class="icon-box shadow-sm flex-shrink-0">
                                    <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                        <circle cx="9" cy="7" r="4"></circle>
                                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                    </svg>
                                </div>
                            </div>

                            <div class="mb-4">
                                <div class="d-flex align-items-end gap-2 mb-3">
                                    <h3 class="fw-bold text-dark mb-0">@dept.NumeroEmpleados</h3>
                                    <span class="text-muted small pb-1">empleados</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-muted small fw-medium">Salario Promedio</span>
                                    <span class="fw-semibold small text-dark">@dept.SalarioPromedio.ToString("N0") €</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted small fw-medium">Ppto. Anual</span>
                                    <span class="fw-bold small" style="color: var(--secondary-color);">@dept.PresupuestoAnual.ToString("N0") €</span>
                                </div>
                            </div>

                            <!-- Botonera -->
                            <div class="d-flex gap-2 mt-auto">
                                @Html.AntiForgeryToken()

                                <a asp-controller="Departaments" asp-action="Details" asp-route-id="@dept.Id"
                                   class="btn-action-custom btn-light-custom flex-grow-1 text-decoration-none"
                                   title="Ver equipo">
                                    Ver Detalle
                                </a>

                                <button onclick="openAddEmployeeModal('@dept.Id', '@dept.Nombre')"
                                        class="btn-action-custom btn-outline-custom-add flex-grow-1"
                                        title="Añadir Empleado">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <line x1="12" y1="5" x2="12" y2="19"></line>
                                        <line x1="5" y1="12" x2="19" y2="12"></line>
                                    </svg>
                                    Añadir
                                </button>

                                <button class="btn-action-custom btn-icon-only" title="Editar"
                                        data-bs-toggle="modal" data-bs-target="#modal-update-department"
                                        data-id="@dept.Id"
                                        data-nombre="@dept.Nombre"
                                        data-presupuesto="@dept.PresupuestoAnual.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                    </svg>
                                </button>

                                <button class="btn-action-custom btn-icon-only btn-delete" title="Eliminar"
                                        data-url="/Departaments/Delete/@dept.Id"
                                        data-name="@dept.Nombre">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="3 6 5 6 21 6"></polyline>
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                    </svg>
                                </button>

                            </div>
                        </div>
                    </div>
                    delayMulti++;
                }
            }
        </div>
    }
    else
    {
        <div class="col-12 kpi-wrapper">
            <div class="card empty-state-card text-center p-5 mx-auto" style="max-width: 600px;">
                <div class="mb-4">
                    <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center"
                         style="width: 80px; height: 80px; background: linear-gradient(135deg, rgba(59, 155, 173, 0.1), rgba(59, 155, 173, 0.05)); color: var(--secondary-color);">
                        <svg width="36" height="36" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                        </svg>
                    </div>
                </div>

                <h5 class="fw-bold text-dark-heading mb-2">Aún no hay departamentos</h5>

                <p class="text-muted mb-4">
                    Empieza creando el primer departamento para organizar equipos,
                    presupuestos y gestionar a tus empleados de forma eficiente.
                </p>

                <div class="d-flex justify-content-center">
                    <button class="btn btn-primary d-flex align-items-center gap-2 px-4 shadow-sm rounded-pill"
                            style="background-color: var(--secondary-color); border-color: var(--secondary-color);"
                            data-bs-toggle="modal"
                            data-bs-target="#modal-add-department">
                        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        Crear mi primer departamento
                    </button>
                </div>
            </div>
        </div>
    }

</div>

<partial name="_IndexModals" model="new NexusERP.ViewModels.CreateDepartamentoViewModel()" />

@section Scripts {
    <script src="~/js/departamentos-index.js" asp-append-version="true"></script>
}